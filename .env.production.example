# =============================================================
# CP System — variáveis de ambiente PRODUÇÃO (Vercel)
# =============================================================
# NÃO comite este arquivo preenchido. Use só como referência.
# Configure cada variável em: Vercel → Project → Settings → Environment Variables
# =============================================================

# Postgres (Neon) — copie a Connection String do dashboard Neon
# Formato: postgresql://USER:PASS@HOST.neon.tech/DBNAME?sslmode=require
DATABASE_URL=""

# Sessão — gere com: openssl rand -base64 32 (NUNCA reutilizar a do dev)
AUTH_SECRET=""

# URL pública do site — atualize após conectar o domínio
AUTH_URL="https://cpsystem.com.br"

# =============================================================
# IA — Extração automática de PDFs (Atas, Contratos, Empenhos)
# =============================================================
# Pegue em https://console.anthropic.com (modelo: claude-haiku-4-5)
ANTHROPIC_API_KEY=""

# =============================================================
# GATEWAY DE PAGAMENTO
# =============================================================
# Comece em DEMO até cadastrar no Asaas/Stripe; depois troque pra ASAAS
GATEWAY_PROVIDER="DEMO"

# Quando configurar Asaas (https://www.asaas.com/customer/integrations):
# ASAAS_API_KEY=""
# ASAAS_AMBIENTE="production"
# ASAAS_WEBHOOK_TOKEN=""
# Webhook URL pra cadastrar no Asaas: https://cpsystem.com.br/api/webhooks/asaas
