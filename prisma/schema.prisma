// CP System — schema Prisma
// PostgreSQL em produção (Neon/Supabase) e dev. Multi-tenant: cada Conta tem 1+ Empresas e 1+ Usuários.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH / TENANCY
// ============================================================

enum TipoConta {
  EMPRESA
  ANALISTA
}

enum Plano {
  BASICO
  INTERMEDIARIO
  PREMIUM
}

enum StatusAssinatura {
  TRIAL
  ATIVA
  INADIMPLENTE
  CANCELADA
}

model Conta {
  id                      String           @id @default(cuid())
  tipo                    TipoConta        @default(EMPRESA)
  plano                   Plano            @default(BASICO)
  statusAssinatura        StatusAssinatura @default(TRIAL)
  trialAteEm              DateTime?
  proximoVencimento       DateTime?
  termosAceitosEm         DateTime?
  // Versao do contrato aceita (Regina 13/07). Permite forcar re-aceite apos
  // bump de versao — se termosAceitosVersao != VERSAO atual do contrato do
  // tipo da conta, o /termos volta a mostrar botao "Li e aceito".
  termosAceitosVersao     String?
  // Cupom aplicado no signup (trial estendido + analista vinculado). Regina 09/07.
  cupomAplicadoId         String?
  cupomAplicado           Cupom?           @relation(fields: [cupomAplicadoId], references: [id])
  embaixadorId            String? // analista que indicou esta conta (programa de embaixadores SaaS — não confundir com VinculoAnalista B2G)
  // Programa de referral cliente-indica-cliente (Regina 08/06, plano marketing v7).
  // Quando cliente atual compartilha link `/conta/indicar` e outra empresa
  // se cadastra via ?ref=conta-<id>, fica vinculada aqui. A cada indicacao
  // que paga 1a fatura, o cliente que indicou ganha 1 mes gratis (creditado
  // como Cobranca de valor 0 no proximo ciclo).
  indicadoPorContaId      String?
  // Gateway de pagamento (ASAAS por padrão)
  gatewayProvider         GatewayProvider?
  gatewayCustomerId       String? // customer_id no gateway
  gatewaySubscriptionId   String? // subscription_id no gateway
  ultimaTentativaCobranca DateTime?
  bloqueadoEm             DateTime?
  // Regina 13/07: cliente escolhe dia de vencimento fixo pra cobrança mensal
  // (10, 15 ou 20). Primeiro nextDueDate = próximo dia escolhido APÓS trial.
  // Asaas renova mensalmente respeitando esse dia.
  diaVencimento           Int? // 10, 15 ou 20
  // CPF do titular do cartão (obrigatório pra tokenização Asaas).
  // Pode ser diferente do CNPJ da empresa (representante legal).
  cpfTitularCartao        String? // apenas dígitos, 11 chars
  // Conciliação bancária (Regina 21/07): feature INTERMEDIARIO+PREMIUM.
  // Cliente escolhe janela mensal (dia 1-31) — cron dispara lembretes 5d/1d/no dia.
  // null = não configurado (opt-out). Se plano BASICO, ignorar mesmo se preenchido.
  conciliacaoDiaMes       Int?
  conciliacaoOptIn        Boolean          @default(true)
  criadoEm                DateTime         @default(now())
  atualizadoEm            DateTime         @updatedAt

  usuarios         Usuario[]
  empresas         Empresa[]
  analista         Analista?
  extratos         Extrato[]
  embaixador       Analista?         @relation("ContasIndicadas", fields: [embaixadorId], references: [id])
  // Cliente que indicou esta conta (referral C2C).
  indicadoPor      Conta?            @relation("ContasIndicadasPorCliente", fields: [indicadoPorContaId], references: [id], onDelete: SetNull)
  // Contas que esta conta indicou.
  contasIndicadas  Conta[]           @relation("ContasIndicadasPorCliente")
  comissoes        Comissao[]
  chamadosSuporte  ChamadoSuporte[]
  logsAuditoria    LogAuditoria[]
  cobrancas        Cobranca[]
  metodosPagamento MetodoPagamento[]
  vinculosAnalista VinculoAnalista[]

  @@index([indicadoPorContaId])
}

enum GatewayProvider {
  ASAAS
  STRIPE
  DEMO // sem gateway real, simulação local
}

enum PerfilUsuario {
  ADMIN
  OPERACIONAL
  VISUALIZADOR
}

model Usuario {
  id                  String        @id @default(cuid())
  nome                String
  email               String        @unique
  senhaHash           String
  perfil              PerfilUsuario @default(ADMIN)
  superAdmin          Boolean       @default(false) // gestor da plataforma (Igor) — vê tudo
  emailVerificadoEm   DateTime?
  // Notificacoes WhatsApp (Regina 02/07): opt-in por usuario. Telefone
  // em E.164 sem "+" (ex: 5521997209623). optIn ausente = sem envio.
  telefoneWhatsApp    String?
  optInWhatsApp       Boolean       @default(false)
  // Dados pessoais completados no onboarding do 1o login (Regina 02/07).
  // Contas migradas (ex: Igor -> Leo) chegam com dados null e usuario
  // preenche antes de acessar o sistema. dataNascimento tambem serve
  // pra CP System mandar mensagem de aniversario no dia.
  cpf                 String?
  cargo               String?
  dataNascimento      DateTime?
  onboardingConcluido Boolean       @default(true)
  criadoEm            DateTime      @default(now())
  atualizadoEm        DateTime      @updatedAt

  contaId String
  conta   Conta  @relation(fields: [contaId], references: [id], onDelete: Cascade)

  sessoes                     Sessao[]
  magicLinks                  MagicLink[]
  dispositivosConhecidos      DispositivoConhecido[]
  chamadosSuporte             ChamadoSuporte[]
  logsAuditoria               LogAuditoria[]
  notificacoesSistema         NotificacaoSistema[]
  mensagensIAsystem           MensagemIAsystem[]
  // Quem criou cada documento — base da regra "só edita criador + admin"
  atasCriadas                 Ata[]                     @relation("AtasCriadas")
  contratosCriados            Contrato[]                @relation("ContratosCriados")
  empenhosCriados             Empenho[]                 @relation("EmpenhosCriados")
  pareceresCriados            ParecerJuridico[]         @relation("ParecresCriados")
  avulsosJuridicosCriados     DocumentoAvulsoJuridico[] @relation("AvulsosCriados")
  reajustesRetroativosCriados ReajusteRetroativo[]      @relation("ReajustesRetroativosCriados")
  contaGoogle                 GoogleAccount?
  notificacoesWhats           NotificacaoWhatsApp[]
  cuponsCriados               Cupom[]                   @relation("CuponsCriados")

  @@index([contaId])
}

// Historico de notificacoes WhatsApp enviadas (Regina 02/07).
// Serve pra:
//   1. Idempotencia: unique(tipo, referenciaId) evita disparar 2x
//   2. Auditoria: rastreio de o que foi enviado e quando
//   3. Debug: registro do erro se Z-API falhar
enum TipoNotificacaoWhatsApp {
  VENCIMENTO_EMPENHO
  ENTREGA_HOJE
  ENTREGA_AMANHA
  VENCIMENTO_PLANO
  PLANO_ATRASADO
  RELATORIO_SEMANAL
  TESTE_MANUAL
  // Fase 2
  SALDO_ATA_BAIXO
  NF_SEM_PAGAMENTO_30D
  CARTAO_EXPIRANDO
  GARANTIA_VENCENDO
  PROCEDIMENTO_APURATORIO
  PARECER_JURIDICO
  ANALISTA_VINCULADO
  COMISSAO_LIBERADA
  REAJUSTE_APROVADO
  ANIVERSARIO
  NF_EMITIDA_CLIENTE
  // Regina 14/07: resumos consolidados semanais (cap 1 msg/semana por
  // destinatario garantido pela chave (usuarioId, tipo, referenciaId=YYYY-Wxx)).
  RESUMO_SEMANAL_EMPRESA
  RESUMO_SEMANAL_ANALISTA
  // Regina 22/07 — alerta de seguranca em login de dispositivo novo.
  // Bypassa opt-in e cap diario (dispararNotificacao com bypassCap=true).
  SEGURANCA_LOGIN_NOVO_DEVICE
}

enum StatusNotificacaoWhatsApp {
  PENDENTE
  ENVIADA
  FALHOU
}

model NotificacaoWhatsApp {
  id           String                    @id @default(cuid())
  usuarioId    String
  usuario      Usuario                   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  tipo         TipoNotificacaoWhatsApp
  // ID do recurso ao qual a notificacao se refere (empenhoId, cobrancaId,
  // etc.). Combinado com `tipo` da chave de idempotencia. null pra tipos
  // sem referencia (relatorio_semanal usa competencia YYYY-WW).
  referenciaId String?
  telefone     String // E.164 sem "+"
  mensagem     String                    @db.Text
  status       StatusNotificacaoWhatsApp @default(PENDENTE)
  enviadaEm    DateTime?
  erro         String?
  criadoEm     DateTime                  @default(now())

  @@unique([usuarioId, tipo, referenciaId])
  @@index([usuarioId, criadoEm])
  @@index([status])
}

// Conta Google conectada via OAuth (Igor 26/06). 1 conta Google por
// usuario do CP System. Empenhos criados por esse usuario sincronizam
// pro Google Calendar dele. accessToken expira em ~1h; refreshToken
// usado pra renovar.
model GoogleAccount {
  id           String   @id @default(cuid())
  usuarioId    String   @unique
  usuario      Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  googleEmail  String
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  // Calendario destino: null = primary (calendario principal do usuario)
  calendarId   String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

// Histórico do chat com o IAsystem — uma linha por mensagem, isolada por
// usuário (cada login tem seu próprio histórico, não compartilha mesmo no
// mesmo navegador). Onde role = "user" (pergunta) ou "assistant" (resposta).
model MensagemIAsystem {
  id         String    @id @default(cuid())
  usuarioId  String
  usuario    Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  role       String // "user" | "assistant"
  content    String    @db.Text
  criadoEm   DateTime  @default(now())
  // Soft delete — quando o usuario limpa o historico, marca esse campo
  // em vez de deletar a linha. Isso preserva a contagem de cota diaria
  // do plano Basico (2 perguntas/dia) mesmo apos 'Limpar historico'
  // (Regina 02/06: a cota volta no dia seguinte, nao quando o usuario
  // limpa).
  deletadaEm DateTime?

  @@index([usuarioId, criadoEm])
}

model Sessao {
  id        String   @id @default(cuid())
  token     String   @unique
  usuarioId String
  expiraEm  DateTime
  criadoEm  DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
}

// MagicLink: login sem senha via link unico enviado por WA/email (Regina 13/07).
// Usado pra pedir migracao pro Leo — clique cria sessao direto e redireciona.
// - token = URL-safe rand hex (mesmo padrao de Sessao)
// - expiraEm = 48h (curto pra reduzir janela de uso indevido)
// - usadoEm = timestamp da 1a utilizacao (bloqueia reuso)
// - motivo = string livre pra auditoria ("migracao_leo", "onboarding_igor" etc.)
model MagicLink {
  id        String    @id @default(cuid())
  token     String    @unique
  usuarioId String
  motivo    String
  criadoPor String? // usuarioId do super admin que gerou (auditoria)
  expiraEm  DateTime
  usadoEm   DateTime?
  criadoEm  DateTime  @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([expiraEm])
}

// ============================================================
// EMPRESA (multi-CNPJ)
// ============================================================

enum PorteEmpresa {
  MEI
  ME
  EPP
  MEDIA
  GRANDE
}

model Empresa {
  id               String       @id @default(cuid())
  razaoSocial      String
  nomeFantasia     String?
  cnpj             String       @unique
  porte            PorteEmpresa
  cnaePrincipal    String?
  cnaesSecundarios String?
  naturezaJuridica String
  endereco         String
  complemento      String?
  cep              String
  email            String // primário (legado mantido pra not break queries existentes)
  emails           String[]     @default([])
  telefones        String // primário (legado)
  telefonesLista   String[]     @default([])
  responsavel      String
  criadoEm         DateTime     @default(now())
  atualizadoEm     DateTime     @updatedAt

  contaId String
  conta   Conta  @relation(fields: [contaId], references: [id], onDelete: Cascade)

  atas                       Ata[]
  contratos                  Contrato[]
  empenhos                   Empenho[]
  documentosAvulsosJuridicos DocumentoAvulsoJuridico[]

  @@index([contaId])
}

// ============================================================
// ANALISTA + EMBAIXADORES + COMISSÕES
// ============================================================

enum TierEmbaixador {
  BRONZE // 1-5 ativos = 3%
  PRATA // 6-10 ativos = 4%
  OURO // 11-15 ativos = 5%
  DIAMOND // 15+ ativos = 6%
}

model Analista {
  id               String        @id @default(cuid())
  nomeCompleto     String
  cpf              String        @unique
  telefone         String
  endereco         String
  cep              String?
  complemento      String?
  email            String
  banco            String?
  agencia          String?
  contaCorrente    String?
  pix              String?
  razaoSocial      String?
  nomeFantasia     String?
  cnpj             String?
  // Pessoa jurídica adicional (opcional — preenchido se o analista emite nota como PJ)
  porte            PorteEmpresa?
  cnaePrincipal    String?
  cnaesSecundarios String?
  naturezaJuridica String?
  enderecoPj       String?
  emailPj          String?
  telefonePj       String?
  divulgacaoUrl    String? // link da bio com o programa
  ativo            Boolean       @default(true)
  criadoEm         DateTime      @default(now())
  atualizadoEm     DateTime      @updatedAt

  contaId String? @unique
  conta   Conta?  @relation(fields: [contaId], references: [id], onDelete: Cascade)

  contasIndicadas   Conta[]            @relation("ContasIndicadas")
  comissoes         Comissao[]
  vinculos          VinculoAnalista[]
  comissoesExecucao ComissaoExecucao[]
  cuponsGerados     Cupom[]            @relation("CuponsGerados")
}

// ============================================================
// CUPOM (Regina 09/07) — trial estendido + vínculo analista automático
// ============================================================
// Cupom criado por admin (você) e passado pra cliente novo. Ao aplicar no
// signup: (1) trial de N dias em vez dos 14 padrão; (2) se analistaVinculadoId
// preenchido, vincula automaticamente esse analista como embaixador da conta.
model Cupom {
  id                  String    @id @default(cuid())
  codigo              String    @unique
  descricao           String? // interno — pra você lembrar por que criou
  diasTrial           Int       @default(60)
  analistaVinculadoId String? // se setado, vira Conta.embaixadorId ao usar
  analistaVinculado   Analista? @relation("CuponsGerados", fields: [analistaVinculadoId], references: [id])
  validoAte           DateTime? // opcional — depois disso não aceita
  usosMaximos         Int? // null = ilimitado
  usosAtuais          Int       @default(0)
  ativo               Boolean   @default(true)
  criadoPorId         String?
  criadoPor           Usuario?  @relation("CuponsCriados", fields: [criadoPorId], references: [id])
  criadoEm            DateTime  @default(now())

  contasAplicadas Conta[]

  @@index([codigo])
  @@index([ativo])
  @@index([analistaVinculadoId])
}

// ============================================================
// VÍNCULO GRUPO ↔ ANALISTA (modelo B2G)
// ============================================================
// Tabela associativa que carrega os atributos do vínculo: data de início
// (regra crítica de comissionamento), percentual, fixo mensal e status.
// O analista comissiona apenas execuções com criadoEm >= dataInicio.
//
// Hoje ainda existe Conta.embaixadorId pra modelo de embaixador SaaS;
// ambos coexistem (são comissões de naturezas diferentes).

enum StatusVinculoAnalista {
  ATIVO
  ENCERRADO
}

model VinculoAnalista {
  id         String   @id @default(cuid())
  contaId    String
  conta      Conta    @relation(fields: [contaId], references: [id], onDelete: Cascade)
  analistaId String
  analista   Analista @relation(fields: [analistaId], references: [id], onDelete: Cascade)

  dataInicio         DateTime              @default(now())
  percentualComissao Float                 @default(0)
  fixoMensal         Float                 @default(0)
  diaVencimentoFixo  Int                   @default(5)
  status             StatusVinculoAnalista @default(ATIVO)
  encerradoEm        DateTime?
  observacoes        String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  fixosPagos        PagamentoFixoMensal[]
  comissoesExecucao ComissaoExecucao[]

  @@unique([contaId, analistaId, dataInicio])
  @@index([contaId])
  @@index([analistaId])
  @@index([status])
}

// Status da comissão fixa mensal. Mesmo conceito da Linha B variável, mas
// sem o estado AGUARDANDO_ORGAO (o fixo independe do pagamento do órgão).
enum StatusComissaoFixa {
  A_RECEBER
  ATRASADO
  PAGO
  PAGO_PARCIAL
}

// Histórico de pagamentos do fixo mensal (por competência).
// Uma linha por VinculoAnalista × competência (YYYY-MM). Geradas automaticamente
// pelo cron diário na primeira passagem após a virada do mês.
model PagamentoFixoMensal {
  id             String             @id @default(cuid())
  vinculoId      String
  vinculo        VinculoAnalista    @relation(fields: [vinculoId], references: [id], onDelete: Cascade)
  competencia    String // YYYY-MM
  valor          Float
  // Vencimento por linha (editável) — snapshot de diaVencimentoFixo no momento
  // da criação. Mudanças posteriores no vínculo não afetam linhas já geradas.
  vencimento     DateTime?
  status         StatusComissaoFixa @default(A_RECEBER)
  valorRecebido  Float              @default(0)
  comprovanteUrl String?
  // Campos legados — mantidos pra compatibilidade. `paga` espelha status === PAGO.
  paga           Boolean            @default(false)
  pagaEm         DateTime?
  observacoes    String?
  criadoEm       DateTime           @default(now())
  atualizadoEm   DateTime           @default(now()) @updatedAt

  @@unique([vinculoId, competencia])
  @@index([vinculoId])
  @@index([status])
}

model Comissao {
  id              String         @id @default(cuid())
  analistaId      String
  contaId         String
  competencia     String // YYYY-MM
  valorBase       Float // MRR da conta
  tier            TierEmbaixador
  percentual      Float // 3, 4, 5 ou 6
  valor           Float
  paga            Boolean        @default(false)
  pagaEm          DateTime?
  criadoEm        DateTime       @default(now())
  // Regina 13/07: rastreio do PIX out automático (cron dia 20).
  transferenciaId String? // ID retornado pelo Asaas Transfer API
  ultimoErroPgto  String? // Última mensagem de erro na tentativa

  analista Analista @relation(fields: [analistaId], references: [id], onDelete: Cascade)
  conta    Conta    @relation(fields: [contaId], references: [id], onDelete: Cascade)

  @@unique([analistaId, contaId, competencia])
  @@index([analistaId])
  @@index([contaId])
}

// ============================================================
// CONTRATAÇÕES
// ============================================================

enum TipoObjeto {
  FORNECIMENTO
  FORNECIMENTO_CONTINUO
  SERVICOS
  SERVICOS_CONTINUOS
  SERVICOS_DEDICACAO_EXCLUSIVA
  LOCACAO
  OBRAS_ENGENHARIA
}

// Modalidade de entrega do contrato (Lei 14.133 — fluxograma do contrato não-continuado).
// INTEGRAL = todo o quantitativo de uma vez.
// PARCELADA = lotes com prazos distintos (ver ParcelaContrato).
// SOB_DEMANDA = quantidade estimativa, sem cronograma fixo (cada empenho/AF puxa do saldo).
enum ModalidadeEntrega {
  INTEGRAL
  PARCELADA
  SOB_DEMANDA
}

// Unidade em que o prazo de entrega/execução é expresso. Default DIAS pra
// retrocompat com registros antigos (todos cadastrados como dias até aqui).
enum PrazoEntregaUnidade {
  DIAS
  MESES
  ANOS
}

// Modo de inclusão do prazo de entrega. RELATIVO = qtd+unidade contada a
// partir do pedido (típico de Fornecimento). DATA_CERTA = data fixa de
// execução (típico de Locação para evento). SOB_DEMANDA = data definida
// posteriormente pelo cliente — prazo/data ficam vazios no Contrato.
// PRAZO_CERTO = janela com inicio e fim (típico de obra/servico com periodo
// fechado — começa em X, encerra em Y).
enum PrazoEntregaModo {
  RELATIVO
  DATA_CERTA
  SOB_DEMANDA
  PRAZO_CERTO
}

// Marco a partir do qual conta o prazo de entrega.
// O contrato define qual é (Lei 14.133 — fluxograma do contrato não-continuado).
enum MarcoInicialPrazoEntrega {
  ASSINATURA_CONTRATO
  ORDEM_FORNECIMENTO
  OUTRO
}

enum ProcedimentoSelecao {
  PREGAO_ELETRONICO
  PREGAO_ELETRONICO_INTERNACIONAL
  PREGAO_PRESENCIAL
  CONCORRENCIA
  CONCURSO
  LEILAO
  DIALOGO_COMPETITIVO
  DISPENSA
  INEXIGIBILIDADE
}

enum Moeda {
  BRL
  USD
  EUR
}

enum TipoOrgaoNaAta {
  GERENCIADOR
  PARTICIPANTE
  CARONA
}

enum FuncaoPontoFocal {
  GESTOR
  FISCAL_TECNICO
  FISCAL_ADMINISTRATIVO
  RESPONSAVEL_SETOR
  CONTATO_GERAL
  AUTORIDADE_COMPETENTE
  FISCAL
  OUTRO
}

enum MarcoReajusteOrigem {
  ORCAMENTO_ESTIMADO
  ASSINATURA
  OMISSA
}

model Ata {
  id                     String              @id @default(cuid())
  tipo                   TipoObjeto
  numero                 String
  processoAdministrativo String
  procedimentoSelecao    ProcedimentoSelecao
  numeroLicitacao        String?

  // Órgão GERENCIADOR (sempre 1, snapshot legado pra compatibilidade)
  orgaoNome     String
  orgaoCnpj     String
  orgaoEndereco String
  orgaoEmail    String?
  orgaoTelefone String?

  objeto                 String
  dataAssinatura         DateTime
  dataPublicacao         DateTime?
  vigenciaInicio         DateTime
  vigenciaFim            DateTime
  prazoEntregaDias       Int?
  prazoEntregaUnidade    PrazoEntregaUnidade  @default(DIAS)
  prazoEntregaNaoAplica  Boolean              @default(false)
  prazoPagamentoDias     Int?
  marcoOrcamentoEstimado DateTime?
  // Origem do marco de reajuste (briefing PDF — Cadastro Ata 2.4)
  marcoReajusteOrigem    MarcoReajusteOrigem?

  aceitaCarona  Boolean @default(false)
  idAtaPncp     String?
  arquivoPdfUrl String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  // Quem criou — null em registros legados (preexistentes à feature).
  // Regra de edição: criador OU usuário ADMIN/superAdmin da conta. Registros
  // legados ficam restritos a ADMIN/superAdmin.
  criadoPorId String?
  criadoPor   Usuario? @relation("AtasCriadas", fields: [criadoPorId], references: [id])

  itens            AtaItem[]
  contratos        Contrato[]
  empenhos         Empenho[]
  orgaos           OrgaoNaAta[]
  enderecosEntrega EnderecoEntrega[]
  pontosFocais     PontoFocal[]
  notificacoes     Notificacao[]
  procedimentos    ProcedimentoApuratorio[]
  anexos           Anexo[]
  anotacoes        Anotacao[]
  termosAditivos   TermoAditivo[]
  apostilamentos   Apostilamento[]
  vigencias        Vigencia[]
  pareceres        ParecerJuridico[]
  atestados        AtestadoCapacidade[]

  @@index([empresaId])
  @@index([criadoPorId])
}

model AtaItem {
  id            String  @id @default(cuid())
  descricao     String
  unidade       String
  quantidade    Float
  marca         String?
  valorUnitario Float
  valorTotal    Float
  moeda         Moeda   @default(BRL)
  // Lote (briefing PDF — Cadastro Ata 2.7: itens agrupados em lotes)
  lote          String?
  // Número do item dentro do lote (ou global se isolado). Texto livre pra
  // permitir "01", "1.A", etc. Validação de unicidade Lote+numero é feita
  // na action de criação (não constraint do banco).
  numero        String?

  ataId String
  ata   Ata    @relation(fields: [ataId], references: [id], onDelete: Cascade)

  // Vigência da Ata a que o item pertence (Lei 14.133 — Ata 1+1 ano).
  // Nullable em registros pré-feature; backfill atribui à vigência 1.
  vigenciaId String?
  vigencia   Vigencia? @relation(fields: [vigenciaId], references: [id], onDelete: SetNull)

  contratoItens ContratoItem[]
  empenhoItens  EmpenhoItem[]

  @@index([ataId])
  @@index([vigenciaId])
}

model OrgaoNaAta {
  id          String         @id @default(cuid())
  ataId       String
  ata         Ata            @relation(fields: [ataId], references: [id], onDelete: Cascade)
  tipo        TipoOrgaoNaAta
  nome        String
  cnpj        String
  endereco    String
  email       String?
  telefone    String?
  // Carona: limites de adesão
  limiteValor Float? // valor monetário máximo permitido a esse carona
  limitePct   Float? // % do total da Ata (default sistema: 50% por órgão)

  enderecosEntrega EnderecoEntrega[]
  pontosFocais     PontoFocal[]

  @@index([ataId])
}

model EnderecoEntrega {
  id           String      @id @default(cuid())
  rotulo       String?
  endereco     String
  ataId        String?
  ata          Ata?        @relation(fields: [ataId], references: [id], onDelete: Cascade)
  contratoId   String?
  contrato     Contrato?   @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  empenhoId    String?
  empenho      Empenho?    @relation(fields: [empenhoId], references: [id], onDelete: Cascade)
  orgaoNaAtaId String?
  orgaoNaAta   OrgaoNaAta? @relation(fields: [orgaoNaAtaId], references: [id], onDelete: Cascade)

  @@index([ataId])
  @@index([contratoId])
  @@index([empenhoId])
  @@index([orgaoNaAtaId])
}

model PontoFocal {
  id              String           @id @default(cuid())
  funcao          FuncaoPontoFocal
  // Descrição livre quando funcao = OUTRO (briefing PDF — Cadastro Ata 2.6)
  funcaoDescricao String?
  nome            String
  email           String?
  telefone        String?
  ataId           String?
  ata             Ata?             @relation(fields: [ataId], references: [id], onDelete: Cascade)
  contratoId      String?
  contrato        Contrato?        @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  empenhoId       String?
  empenho         Empenho?         @relation(fields: [empenhoId], references: [id], onDelete: Cascade)
  orgaoNaAtaId    String?
  orgaoNaAta      OrgaoNaAta?      @relation(fields: [orgaoNaAtaId], references: [id], onDelete: Cascade)

  @@index([ataId])
  @@index([contratoId])
  @@index([empenhoId])
  @@index([orgaoNaAtaId])
}

model Contrato {
  id                     String              @id @default(cuid())
  tipo                   TipoObjeto
  numero                 String
  numeroNotaEmpenho      String?
  processoAdministrativo String
  procedimentoSelecao    ProcedimentoSelecao
  numeroLicitacao        String?

  orgaoNome     String
  orgaoCnpj     String
  orgaoEndereco String
  orgaoEmail    String?
  orgaoTelefone String?

  objeto                 String
  dataAssinatura         DateTime
  dataPublicacao         DateTime?
  vigenciaInicio         DateTime
  vigenciaFim            DateTime
  prazoEntregaDias       Int?
  prazoEntregaUnidade    PrazoEntregaUnidade  @default(DIAS)
  // Modo de prazo de entrega: RELATIVO usa qtd+unidade (prazoEntregaDias),
  // DATA_CERTA usa dataEntregaCerta (ex.: locação de evento com data fixa).
  prazoEntregaModo       PrazoEntregaModo     @default(RELATIVO)
  dataEntregaCerta       DateTime?
  prazoPagamentoDias     Int?
  marcoOrcamentoEstimado DateTime?
  marcoReajusteOrigem    MarcoReajusteOrigem?

  // Valor inicial do contrato (somatório de itens no momento da criação).
  // Preservado pra exibir "Valor Inicial" mesmo após aditivos com reajuste.
  // null em contratos pré-M3-aditivo (backfill aplica o valor corrente).
  valorInicial Float?

  // Fluxograma da contratação — Lei 14.133 (contratos não-continuados):
  // como o quantitativo é entregue e qual o marco inicial do prazo.
  modalidadeEntrega     ModalidadeEntrega         @default(INTEGRAL)
  marcoInicialPrazo     MarcoInicialPrazoEntrega? // null quando SOB_DEMANDA (não há prazo único)
  marcoInicialDescricao String? // só preenchido quando marcoInicialPrazo = OUTRO

  // M5 Garantia — tri-estado: null = não declarado, true = há previsão,
  // false = explicitamente sem previsão (usuário marcou "Não" e salvou).
  temGarantia Boolean?

  // Documentos de suporte do contrato (Lei 14.133)
  numeroOrdemFornecimento String? // ex: "OF 042/2024" — quando o órgão emite OF/AF
  arquivoOfUrl            String?

  arquivoPdfUrl String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  ataId String?
  ata   Ata?    @relation(fields: [ataId], references: [id])

  criadoPorId String?
  criadoPor   Usuario? @relation("ContratosCriados", fields: [criadoPorId], references: [id])

  itens            ContratoItem[]
  parcelas         ParcelaContrato[]
  empenhos         Empenho[]
  enderecosEntrega EnderecoEntrega[]
  pontosFocais     PontoFocal[]
  termosAditivos   TermoAditivo[]
  apostilamentos   Apostilamento[]
  reajustes        Reajuste[]
  notificacoes     Notificacao[]
  procedimentos    ProcedimentoApuratorio[]
  garantias        Garantia[]
  anexos           Anexo[]
  anotacoes        Anotacao[]
  vigencias        Vigencia[]
  pareceres        ParecerJuridico[]
  atestados        AtestadoCapacidade[]

  @@index([empresaId])
  @@index([ataId])
  @@index([criadoPorId])
}

// Cronograma de entrega quando modalidadeEntrega = PARCELADA.
// Cada parcela tem seu próprio prazo (em dias após o marco inicial) e descrição.
model ParcelaContrato {
  id            String   @id @default(cuid())
  numero        Int
  prazoDias     Int // dias após o marco inicial do contrato
  descricao     String? // ex: "primeiros 50 computadores DELL Inspiron"
  valorEstimado Float?
  criadoEm      DateTime @default(now())

  contratoId String
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@unique([contratoId, numero])
  @@index([contratoId])
}

model ContratoItem {
  id            String  @id @default(cuid())
  descricao     String
  unidade       String
  quantidade    Float
  marca         String?
  valorUnitario Float
  valorTotal    Float
  moeda         Moeda   @default(BRL)

  // Mesmo esquema do AtaItem: contratos podem ser estruturados em
  // Lotes (cada item carrega o rotulo do lote e o numero/posicao
  // dentro do contrato), espelhando a ARP de origem ou um contrato
  // avulso que tenha lotes proprios.
  lote   String?
  numero String?

  contratoId String
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  ataItemId String?
  ataItem   AtaItem? @relation(fields: [ataItemId], references: [id])

  // Vigência do Contrato a que o item pertence. Nullable em registros
  // pré-feature; backfill atribui à vigência 1 do contrato.
  vigenciaId String?
  vigencia   Vigencia? @relation(fields: [vigenciaId], references: [id], onDelete: SetNull)

  @@index([contratoId])
  @@index([ataItemId])
  @@index([vigenciaId])
}

enum StatusExecucao {
  EMPENHADO
  PEDIDO_RECEBIDO
  EM_TRANSITO
  ENTREGUE
  NF_EMITIDA
  NF_ENCAMINHADA
  PAGO
}

// Instrumentos contratuais substitutivos do Termo de Contrato (art. 95,
// Lei 14.133/2021). Todos compartilham o mesmo model Empenho — o campo
// `instrumento` diferencia a natureza jurídica e dispara labels/campos
// específicos no formulário.
enum InstrumentoContratual {
  NOTA_EMPENHO
  CARTA_CONTRATO
  AUTORIZACAO_COMPRA
  AUTORIZACAO_ENTREGA
  ORDEM_SERVICO
}

// ============================================================
// COMISSÃO POR EXECUÇÃO (Linha B — empresa paga analista)
// ============================================================
// Distinção crítica versus Empenho.status === "PAGO":
//   - Empenho.status PAGO = órgão pagou a empresa (Linha A, sem efeito caixa
//     pro analista)
//   - ComissaoExecucao.status PAGO = empresa pagou a comissão ao analista
//     (Linha B, é o que entra no painel "Recebido no mês")
//
// Bug histórico: o sistema considerava Linha A como Linha B, marcando comissão
// como recebida automaticamente. Hoje os dois fluxos são independentes.
enum StatusComissaoExecucao {
  AGUARDANDO_ORGAO // Empenho ainda não foi pago pelo órgão à empresa
  A_RECEBER // Órgão pagou; comissão liberada para cobrança pelo analista
  ATRASADO // A_RECEBER e passou da data combinada (controle do analista)
  PAGO // Empresa pagou a comissão ao analista
  PAGO_PARCIAL // Empresa pagou parcialmente a comissão
}

model ComissaoExecucao {
  id        String  @id @default(cuid())
  empenhoId String
  empenho   Empenho @relation(fields: [empenhoId], references: [id], onDelete: Cascade)

  vinculoId String
  vinculo   VinculoAnalista @relation(fields: [vinculoId], references: [id], onDelete: Cascade)

  analistaId String
  analista   Analista @relation(fields: [analistaId], references: [id], onDelete: Cascade)

  // Snapshot do percentual no momento da criação — protege contra alterações
  // retroativas no vínculo. Quando o admin muda o % no cadastro, vale só pra
  // execuções futuras.
  percentual         Float
  percentualOverride Boolean @default(false) // se foi editado por execução
  observacaoOverride String?

  // Valores monetários
  valorBaseEmpenho Float // snapshot do total empenhado (sem alterações)
  valorBasePago    Float @default(0) // quanto o órgão efetivamente pagou (Linha A)
  valorCalculado   Float // percentual × valorBasePago (a comissão devida)
  valorRecebido    Float @default(0) // quanto o analista já recebeu da empresa

  status         StatusComissaoExecucao @default(AGUARDANDO_ORGAO)
  dataPagamento  DateTime?
  comprovanteUrl String?
  observacao     String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([empenhoId, vinculoId])
  @@index([analistaId, status])
  @@index([vinculoId])
  @@index([empenhoId])
}

model Empenho {
  id                     String                @id @default(cuid())
  tipo                   TipoObjeto
  // Natureza jurídica do registro (art. 95, Lei 14.133/2021). Default cobre
  // legado: empenhos cadastrados antes da feature continuam aparecendo como
  // "Nota de Empenho" sem regressão.
  instrumento            InstrumentoContratual @default(NOTA_EMPENHO)
  numero                 String
  identificador          String? // ex: "1ª parcela", "Solicitação 042/2026"
  processoAdministrativo String
  // Opcional pro Empenho (M3.3, decisão Igor): info redundante quando o
  // Empenho deriva de Ata/Contrato. Continua obrigatório em Ata/Contrato.
  procedimentoSelecao    ProcedimentoSelecao?
  numeroLicitacao        String?

  // Campos específicos por instrumento (todos opcionais — só preenchidos
  // quando o instrumento correspondente exige).
  classificacaoOrcamentaria String? // Nota de Empenho
  signatario                String? // Carta-Contrato
  dataAssinatura            DateTime? // Carta-Contrato
  departamentoEmissor       String? // Autorização de Compra
  pontoColeta               String? // Autorização de Entrega (origem)
  contatoRecebedor          String? // Autorização de Entrega (nome/contato)
  fiscalResponsavel         String? // Ordem de Execução de Serviço

  // M5 Garantia — tri-estado igual ao Contrato.
  temGarantia Boolean?

  orgaoNome     String
  orgaoCnpj     String
  orgaoEndereco String
  orgaoEmail    String?
  orgaoTelefone String?

  objeto                String
  dataEmissao           DateTime
  dataPrevistaExecucao  DateTime? // pra alerta de prazo no painel do analista
  dataPrevistaPagamento DateTime?
  vigenciaInicio        DateTime
  vigenciaFim           DateTime
  prazoEntregaDias      Int?
  prazoEntregaUnidade   PrazoEntregaUnidade @default(DIAS)
  // Módulo 3.3 — modo do prazo: relativo (qtd+unidade) ou data fixa.
  // Mesmo enum compartilhado com Contrato (PrazoEntregaModo).
  prazoEntregaModo      PrazoEntregaModo    @default(RELATIVO)
  dataEntregaCerta      DateTime?
  // Modo PRAZO_CERTO — janela com inicio e fim.
  dataEntregaInicio     DateTime?
  dataEntregaFim        DateTime?
  // Horario da execucao (Igor 26/06): pra servicos/locacoes que tem
  // horario marcado. Strings "HH:MM" (24h). Opcionais — empenhos de
  // fornecimento normalmente nao tem horario.
  horaInicio            String?
  horaFim               String?
  // ID do evento sincronizado no Google Calendar (Igor 26/06). Quando
  // preenchido, ediçoes/exclusoes propagam pro Google. null = nao
  // sincronizado (usuario sem GoogleAccount ou empenho criado antes
  // da integracao).
  googleEventId         String?
  prazoPagamentoDias    Int?

  status StatusExecucao @default(EMPENHADO)

  dataPedidoRecebido    DateTime?
  arquivoPedidoRecebido String?
  dataDespacho          DateTime?
  arquivoDespacho       String?
  dataEntrega           DateTime?
  arquivoEntrega        String?
  dataNfEmitida         DateTime?
  arquivoNfEmitida      String?
  dataNfEncaminhada     DateTime?
  arquivoNfEncaminhada  String?
  dataPagamento         DateTime?
  arquivoPagamento      String?

  // Ordem de Fornecimento/Execução
  numeroOrdemFornecimento String?
  arquivoOfUrl            String?

  arquivoPdfUrl String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  ataId String?
  ata   Ata?    @relation(fields: [ataId], references: [id])

  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id])

  // Vigência (do Contrato OU da Ata) em que esse empenho foi executado.
  // Resolvido automaticamente por dataEmissao na criação; nullable em
  // registros pré-feature (backfill atribui).
  vigenciaId String?
  vigencia   Vigencia? @relation(fields: [vigenciaId], references: [id], onDelete: SetNull)

  criadoPorId String?
  criadoPor   Usuario? @relation("EmpenhosCriados", fields: [criadoPorId], references: [id])

  itens              EmpenhoItem[]
  enderecosEntrega   EnderecoEntrega[]
  pontosFocais       PontoFocal[]
  termosAditivos     TermoAditivo[]
  apostilamentos     Apostilamento[]
  reajustes          Reajuste[]
  notificacoes       Notificacao[]
  procedimentos      ProcedimentoApuratorio[]
  garantias          Garantia[]
  anexos             Anexo[]
  anotacoes          Anotacao[]
  comissoes          ComissaoExecucao[]
  pareceres          ParecerJuridico[]
  reajusteRetroativo ReajusteRetroativo?

  @@index([empresaId])
  @@index([ataId])
  @@index([contratoId])
  @@index([vigenciaId])
  @@index([criadoPorId])
}

model EmpenhoItem {
  id            String  @id @default(cuid())
  descricao     String
  unidade       String
  quantidade    Float
  marca         String?
  valorUnitario Float
  valorTotal    Float
  moeda         Moeda   @default(BRL)

  empenhoId String
  empenho   Empenho @relation(fields: [empenhoId], references: [id], onDelete: Cascade)

  ataItemId String?
  ataItem   AtaItem? @relation(fields: [ataItemId], references: [id])

  @@index([empenhoId])
  @@index([ataItemId])
}

// ============================================================
// ALTERAÇÕES CONTRATUAIS (aditivos, apostilamentos, reajustes)
// ============================================================

enum NaturezaAlteracao {
  VALOR
  PRAZO_VIGENCIA
  PRAZO_ENTREGA
  ESCOPO
  REAJUSTE
  REEQUILIBRIO
  OUTRO
}

model TermoAditivo {
  id             String   @id @default(cuid())
  numero         String
  objeto         String
  dataAssinatura DateTime
  natureza       String // CSV de NaturezaAlteracao (legado)

  // ---- Bloco Valor ----
  alteraValor        Boolean             @default(false)
  tipoAlteracaoValor TipoAlteracaoValor?
  novoValor          Float? // delta do aditivo (positivo p/ acréscimo, pode ser negativo p/ supressão)

  // ---- Bloco Vigência ----
  alteraPrazoVigencia Boolean              @default(false)
  novaVigenciaInicio  DateTime?
  novaVigenciaFim     DateTime?
  novaVigenciaPrazo   Int?
  novaVigenciaUnidade PrazoEntregaUnidade?

  // ---- Bloco Entrega ----
  alteraPrazoEntrega      Boolean              @default(false)
  novoPrazoEntregaDias    Int?
  novoPrazoEntregaUnidade PrazoEntregaUnidade?

  // ---- Bloco Reajuste (aplica em todos os itens do contrato/ata) ----
  aplicaReajuste             Boolean         @default(false)
  reajusteIndice             IndiceReajuste?
  reajusteIndiceOutro        String? // texto livre quando indice=OUTRO
  reajustePeriodoInicio      DateTime?
  reajustePeriodoFim         DateTime?
  reajustePercentual         Float?
  // Data a partir da qual o reajuste tem efeitos financeiros no contrato.
  // Execucoes (Empenhos) com dataEmissao >= esta data usam valor reajustado;
  // anteriores ficam com valor original. Default = data de assinatura do
  // aditivo quando nao informado (comportamento legado).
  reajusteEfeitosFinanceiros DateTime?

  observacoes   String?
  arquivoPdfUrl String?

  // Snapshot dos valores anteriores (JSON) pra reverter no excluir/editar:
  // { valor, vigenciaFim, prazoEntregaDias, prazoEntregaUnidade, itens: [{id, valorUnitario, valorTotal}] }
  dadosAnteriores Json?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @default(now()) @updatedAt

  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  empenhoId  String?
  empenho    Empenho?  @relation(fields: [empenhoId], references: [id], onDelete: Cascade)
  ataId      String?
  ata        Ata?      @relation(fields: [ataId], references: [id], onDelete: Cascade)

  // Vigência que este aditivo originou (quando alterou prazo de vigência).
  // Lado inverso de Vigencia.termoAditivoId (relação 1:1 opcional).
  vigenciaOriginada Vigencia?

  @@index([contratoId])
  @@index([empenhoId])
  @@index([ataId])
}

// Vigência de um Contrato continuado ou Ata — uma "caixa" de execução com
// início, fim e valor próprios. Lei 14.133 permite Atas 1+1 ano e contratos
// contínuos com prorrogações sucessivas; o saldo não-executado de uma
// vigência NÃO cumula com a próxima.
//
// Ordem=1 é a vigência original (criada junto com o Contrato/Ata).
// Ordem>1 vem de Termo Aditivo que prorroga vigência ou via botão manual
// "Iniciar nova vigência". A relação termoAditivoId é única — um aditivo
// só pode originar uma vigência.
model Vigencia {
  id         String   @id @default(cuid())
  ordem      Int
  dataInicio DateTime
  dataFim    DateTime
  valorTotal Float
  observacao String?

  termoAditivoId String?       @unique
  termoAditivo   TermoAditivo? @relation(fields: [termoAditivoId], references: [id], onDelete: SetNull)

  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  ataId String?
  ata   Ata?    @relation(fields: [ataId], references: [id], onDelete: Cascade)

  contratoItens ContratoItem[]
  ataItens      AtaItem[]
  empenhos      Empenho[]

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @default(now()) @updatedAt

  @@unique([contratoId, ordem])
  @@unique([ataId, ordem])
  @@index([contratoId])
  @@index([ataId])
}

// Parecer jurídico gerado pela IA (claude-sonnet-4-6) sobre um documento
// (Ata, Contrato ou Empenho). Persiste o resultado pra evitar re-análise
// (gastando tokens) e dar histórico — usuário pode comparar pareceres
// gerados em datas diferentes (útil quando o contexto do documento muda:
// novo aditivo, mudança de vigência, etc.).
model ParecerJuridico {
  id      String  @id @default(cuid())
  tipo    String // "ATA" | "CONTRATO" | "EMPENHO" | "TERMO_COOPERACAO" | "AVULSO" — TipoDocJuridico
  analise Json // payload AnaliseJuridica completo
  modelo  String // ex: "claude-sonnet-4-6"
  demo    Boolean @default(false) // true se análise mockada (sem API key)

  ataId      String?
  ata        Ata?                     @relation(fields: [ataId], references: [id], onDelete: Cascade)
  contratoId String?
  contrato   Contrato?                @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  empenhoId  String?
  empenho    Empenho?                 @relation(fields: [empenhoId], references: [id], onDelete: Cascade)
  avulsoId   String?
  avulso     DocumentoAvulsoJuridico? @relation(fields: [avulsoId], references: [id], onDelete: Cascade)

  criadoPorId String?
  criadoPor   Usuario? @relation("ParecresCriados", fields: [criadoPorId], references: [id])

  criadoEm DateTime @default(now())

  @@index([ataId, criadoEm])
  @@index([contratoId, criadoEm])
  @@index([empenhoId, criadoEm])
  @@index([avulsoId, criadoEm])
  @@index([criadoPorId])
}

// Documento avulso (PDF) submetido pelo usuário pra análise jurídica.
// Suporta TC (Termo de Cooperação), minutas, aditivos e qualquer PDF
// que não é modelado como entidade própria no sistema.
// Regina 06/07/2026.
model DocumentoAvulsoJuridico {
  id        String  @id @default(cuid())
  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  tipo         String // "TERMO_COOPERACAO" | "MINUTA" | "ADITIVO" | "OUTRO"
  nome         String // nome legível do arquivo
  pdfUrl       String // URL pública no Vercel Blob
  blobPathname String? // caminho interno pra deletar depois
  tamanhoBytes Int?

  pareceres ParecerJuridico[]

  criadoPorId String?
  criadoPor   Usuario? @relation("AvulsosCriados", fields: [criadoPorId], references: [id])

  criadoEm DateTime @default(now())

  @@index([empresaId, criadoEm])
  @@index([criadoPorId])
}

// Reajuste retroativo aplicado em UMA execução específica (Empenho).
// Caso de uso: o órgão deferiu o reajuste após a execução E o pagamento
// já terem ocorrido. A empresa precisa emitir NF complementar da
// diferença e acompanhar o pagamento dela. Ciclo de vida estende a
// timeline da execução com 3 marcos novos (NF complementar emitida,
// encaminhada, paga).
//
// Diferença de Reajuste contratual: o Reajuste contratual (model Reajuste)
// é em nível de Contrato/Ata; o ReajusteRetroativo é em nível de Empenho
// individual e é a "aplicação" do reajuste contratual numa execução que
// já estava paga. Usuário marca um por vez, por execução.
model ReajusteRetroativo {
  id String @id @default(cuid())

  // Snapshot dos valores no momento da aplicação:
  valorOriginal   Float // soma dos itens do empenho ANTES (congelado)
  valorReajustado Float // soma com valorUnitario atual do contrato/ata
  diferenca       Float // valorReajustado - valorOriginal (NF complementar)
  observacao      String?

  dataAplicacao DateTime @default(now())

  // Marcos da NF complementar (timeline estendida)
  dataNfEmitida        DateTime?
  arquivoNfEmitida     String?
  dataNfEncaminhada    DateTime?
  arquivoNfEncaminhada String?
  dataPagamento        DateTime?
  arquivoPagamento     String?

  // 1:1 com Empenho — cada execução tem no máximo um reajuste retroativo
  empenhoId String  @unique
  empenho   Empenho @relation(fields: [empenhoId], references: [id], onDelete: Cascade)

  criadoPorId String?
  criadoPor   Usuario? @relation("ReajustesRetroativosCriados", fields: [criadoPorId], references: [id])

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @default(now()) @updatedAt

  @@index([empenhoId])
  @@index([criadoPorId])
}

model Apostilamento {
  id             String   @id @default(cuid())
  numero         String
  objeto         String
  dataAssinatura DateTime
  natureza       String

  // M3 — Comprasnet layout
  finalidade FinalidadeApostilamento?
  motivo     String?

  // ---- Bloco Valor ----
  alteraValor        Boolean             @default(false)
  tipoAlteracaoValor TipoAlteracaoValor?
  novoValor          Float?

  // ---- Bloco Vigência ----
  alteraPrazoVigencia Boolean              @default(false)
  novaVigenciaInicio  DateTime?
  novaVigenciaFim     DateTime?
  novaVigenciaPrazo   Int?
  novaVigenciaUnidade PrazoEntregaUnidade?

  // ---- Bloco Entrega ----
  alteraPrazoEntrega      Boolean              @default(false)
  novoPrazoEntregaDias    Int?
  novoPrazoEntregaUnidade PrazoEntregaUnidade?

  // ---- Bloco Reajuste ----
  aplicaReajuste             Boolean         @default(false)
  reajusteIndice             IndiceReajuste?
  reajusteIndiceOutro        String?
  reajustePeriodoInicio      DateTime?
  reajustePeriodoFim         DateTime?
  reajustePercentual         Float?
  // Data a partir da qual o reajuste tem efeitos financeiros no contrato
  // (mesmo significado do campo em TermoAditivo).
  reajusteEfeitosFinanceiros DateTime?

  observacoes   String?
  arquivoPdfUrl String?

  // Snapshot do estado anterior pra reverter (mesmo formato do aditivo)
  dadosAnteriores Json?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @default(now()) @updatedAt

  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  empenhoId  String?
  empenho    Empenho?  @relation(fields: [empenhoId], references: [id], onDelete: Cascade)
  ataId      String?
  ata        Ata?      @relation(fields: [ataId], references: [id], onDelete: Cascade)

  @@index([contratoId])
  @@index([empenhoId])
  @@index([ataId])
}

enum InstrumentoReajuste {
  TERMO_ADITIVO
  APOSTILAMENTO
}

enum IndiceReajuste {
  IPCA
  IPCA_E
  IPCA_15
  IGPM
  INCC
  INPC
  IST
  CONTRATUAL
  OUTRO
}

// M3 — Aditivo: classificação da alteração de valor contratual.
// Acréscimo/Supressão = aumenta/reduz quantitativo (Lei 14.133 art. 125).
// Reajuste/Repactuação = aplica índice ou recomposição contratual.
// Reequilíbrio = recompõe equilíbrio econômico-financeiro (art. 124, II, d).
enum TipoAlteracaoValor {
  ACRESCIMO
  SUPRESSAO
  REAJUSTE_REPACTUACAO
  REEQUILIBRIO
}

// M3 — Apostilamento: finalidade conforme Comprasnet.
// Apostilamento (Lei 14.133 art. 136) é alteração unilateral simples
// (não exige novo instrumento) — tipicamente reajuste por índice já
// contratado, penalidade, empenho suplementar ou outra anotação.
enum FinalidadeApostilamento {
  REAJUSTE
  APLICACAO_PENALIDADE
  EMPENHO_CREDITO_SUPLEMENTAR
  OUTROS
}

model Reajuste {
  id                String              @id @default(cuid())
  dataPedido        DateTime
  dataAprovacao     DateTime?
  indice            IndiceReajuste
  percentual        Float
  valorAnterior     Float
  valorNovo         Float
  instrumento       InstrumentoReajuste
  instrumentoNumero String?
  observacoes       String?
  criadoEm          DateTime            @default(now())

  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  empenhoId  String?
  empenho    Empenho?  @relation(fields: [empenhoId], references: [id], onDelete: Cascade)

  @@index([contratoId])
  @@index([empenhoId])
}

// ============================================================
// NOTIFICAÇÕES ADMINISTRATIVAS
// ============================================================

enum StatusNotificacao {
  RECEBIDA
  EM_TRATATIVA
  RESPONDIDA
  FINALIZADA
}

model Notificacao {
  id              String            @id @default(cuid())
  numero          String?
  assunto         String
  descricao       String
  dataRecebimento DateTime
  prazoResposta   Int? // dias
  status          StatusNotificacao @default(RECEBIDA)
  arquivoPdfUrl   String?
  criadoEm        DateTime          @default(now())
  atualizadoEm    DateTime          @updatedAt

  ataId      String?
  ata        Ata?      @relation(fields: [ataId], references: [id], onDelete: Cascade)
  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  empenhoId  String?
  empenho    Empenho?  @relation(fields: [empenhoId], references: [id], onDelete: Cascade)

  andamentos AndamentoNotificacao[]

  @@index([ataId])
  @@index([contratoId])
  @@index([empenhoId])
}

model AndamentoNotificacao {
  id            String            @id @default(cuid())
  notificacaoId String
  notificacao   Notificacao       @relation(fields: [notificacaoId], references: [id], onDelete: Cascade)
  status        StatusNotificacao
  descricao     String
  dataEvento    DateTime
  // M3 — anexar comprovante/resposta junto ao andamento (ex.: PDF da
  // resposta enviada ao órgão, comprovante de entrega de defesa, etc.)
  arquivoPdfUrl String?
  criadoEm      DateTime          @default(now())

  @@index([notificacaoId])
}

// ============================================================
// PROCEDIMENTOS APURATÓRIOS (Lei 14.133/2021 art. 157+)
// ============================================================

enum FaseProcedimento {
  ABERTURA
  NOTIFICACAO_DEFESA
  DEFESA_APRESENTADA
  PEDIDO_PROVAS
  DEFERIMENTO_PROVAS
  NOTIFICACAO_ALEGACOES
  ALEGACOES_FINAIS
  DECISAO_1A_INSTANCIA
  RECURSO
  DECISAO_FINAL
  ARQUIVAMENTO
  PENALIDADE_APLICADA
}

enum TipoPenalidade {
  ADVERTENCIA
  MULTA
  IMPEDIMENTO_LICITAR
  DECLARACAO_INIDONEIDADE
}

model ProcedimentoApuratorio {
  id                String   @id @default(cuid())
  numero            String?
  notificacaoNumero String?
  assunto           String
  descricao         String
  // M3 — comissão agora suporta múltiplos membros (mínimo 2 servidores).
  // `comissao` (CSV legado) mantido pra retrocompatibilidade.
  comissao          String?
  comissaoMembros   String[] @default([])
  autoridade        String? // autoridade competente
  dataAbertura      DateTime
  // Prazos da Lei 14.133 contados em DIAS ÚTEIS.
  // Defesa: art. 157 — 15 dias úteis (padrão).
  // Recurso: art. 165 — 15 dias úteis (padrão).
  prazoDefesaDias   Int      @default(15)
  prazoRecursoDias  Int      @default(15)
  arquivado         Boolean  @default(false)
  arquivoPdfUrl     String?
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt

  ataId      String?
  ata        Ata?      @relation(fields: [ataId], references: [id], onDelete: Cascade)
  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  empenhoId  String?
  empenho    Empenho?  @relation(fields: [empenhoId], references: [id], onDelete: Cascade)

  andamentos  AndamentoProcedimento[]
  penalidades Penalidade[]

  @@index([ataId])
  @@index([contratoId])
  @@index([empenhoId])
}

model AndamentoProcedimento {
  id             String                 @id @default(cuid())
  procedimentoId String
  procedimento   ProcedimentoApuratorio @relation(fields: [procedimentoId], references: [id], onDelete: Cascade)
  fase           FaseProcedimento
  descricao      String
  dataEvento     DateTime
  arquivoPdfUrl  String?
  criadoEm       DateTime               @default(now())

  @@index([procedimentoId])
}

model Penalidade {
  id             String                 @id @default(cuid())
  procedimentoId String
  procedimento   ProcedimentoApuratorio @relation(fields: [procedimentoId], references: [id], onDelete: Cascade)
  tipo           TipoPenalidade
  valor          Float? // pra multa
  duracaoMeses   Int? // pra impedimento/inidoneidade
  fundamentacao  String?
  dataAplicacao  DateTime
  criadoEm       DateTime               @default(now())

  @@index([procedimentoId])
}

// ============================================================
// GARANTIA CONTRATUAL
// ============================================================

enum ModalidadeGarantia {
  SEGURO_GARANTIA
  FIANCA_BANCARIA
  CAUCAO_DINHEIRO
  TITULOS_DIVIDA_PUBLICA
}

model Garantia {
  id            String             @id @default(cuid())
  modalidade    ModalidadeGarantia
  // Seguro-garantia
  seguradora    String?
  // Fiança bancária
  banco         String?
  // Comum
  valor         Float
  dataInicio    DateTime
  dataFim       DateTime?
  descricao     String? // pra títulos da dívida pública e outros
  arquivoPdfUrl String?
  criadoEm      DateTime           @default(now())
  atualizadoEm  DateTime           @updatedAt

  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  empenhoId  String?
  empenho    Empenho?  @relation(fields: [empenhoId], references: [id], onDelete: Cascade)

  endossos Endosso[]

  @@index([contratoId])
  @@index([empenhoId])
}

model Endosso {
  id            String    @id @default(cuid())
  garantiaId    String
  garantia      Garantia  @relation(fields: [garantiaId], references: [id], onDelete: Cascade)
  valor         Float
  dataInicio    DateTime
  dataFim       DateTime?
  observacoes   String?
  arquivoPdfUrl String?
  criadoEm      DateTime  @default(now())

  @@index([garantiaId])
}

// ============================================================
// ANEXOS + ANOTAÇÕES
// ============================================================

enum CategoriaAnexo {
  CONTRATUAL
  ADITIVO
  APOSTILAMENTO
  GARANTIA
  NOTIFICACAO
  PROCEDIMENTO
  NF
  COMPROVANTE
  OUTRO
}

model Anexo {
  id           String         @id @default(cuid())
  nome         String
  url          String // path local /uploads/<id>.<ext>
  mimeType     String?
  tamanhoBytes Int?
  categoria    CategoriaAnexo @default(OUTRO)
  criadoEm     DateTime       @default(now())

  ataId      String?
  ata        Ata?      @relation(fields: [ataId], references: [id], onDelete: Cascade)
  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  empenhoId  String?
  empenho    Empenho?  @relation(fields: [empenhoId], references: [id], onDelete: Cascade)

  @@index([ataId])
  @@index([contratoId])
  @@index([empenhoId])
}

// Atestado de Capacidade Tecnica — emitido pelo orgao ao final do
// Contrato/Ata como comprovacao de que a empresa executou bem. A
// empresa anexa o PDF aqui pra ter catalogado e usar em licitacoes
// futuras (Regina 31/05).
model AtestadoCapacidade {
  id             String   @id @default(cuid())
  numero         String? // nº do atestado (quando o orgao emite numerado)
  dataEmissao    DateTime
  orgaoEmissor   String // nome do orgao que emitiu
  objeto         String? // descricao curta do que foi atestado
  observacoes    String?
  arquivoPdfUrl  String // url do PDF anexado
  arquivoPdfNome String?
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  ataId      String?
  ata        Ata?      @relation(fields: [ataId], references: [id], onDelete: Cascade)
  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@index([ataId])
  @@index([contratoId])
}

model Anotacao {
  id        String   @id @default(cuid())
  texto     String
  autorNome String?
  criadoEm  DateTime @default(now())

  ataId      String?
  ata        Ata?      @relation(fields: [ataId], references: [id], onDelete: Cascade)
  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  empenhoId  String?
  empenho    Empenho?  @relation(fields: [empenhoId], references: [id], onDelete: Cascade)

  @@index([ataId])
  @@index([contratoId])
  @@index([empenhoId])
}

// ============================================================
// LOGS DE AUDITORIA
// ============================================================

enum AcaoAuditoria {
  CRIAR
  ATUALIZAR
  EXCLUIR
  LOGIN
  LOGOUT
  EXPORTAR
  UPLOAD
  DOWNLOAD
}

// Cache de geocodificação por CNPJ. Evita bater no Nominatim toda vez que
// o dashboard carrega. Atualizado on-demand quando um órgão novo aparece
// ou quando o endereço cadastrado muda.
model OrgaoGeocode {
  cnpj         String   @id // CNPJ normalizado (só dígitos)
  endereco     String // endereço usado pra geocodificar (audita re-trigger)
  latitude     Float
  longitude    Float
  precisao     String? // "exact" / "city" / "state" — qualidade do resultado
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

// Cache de geocodificação para endereços de entrega (sem CNPJ associado).
// Usa o próprio endereço normalizado como chave para evitar geocodificar
// duas vezes o mesmo local. Reutiliza o mesmo pool de rate-limit do Nominatim.
model EnderecoGeocode {
  endereco     String   @id // endereço normalizado (trim, lowercase) — chave única
  latitude     Float
  longitude    Float
  precisao     String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model LogAuditoria {
  id        String        @id @default(cuid())
  contaId   String
  conta     Conta         @relation(fields: [contaId], references: [id], onDelete: Cascade)
  usuarioId String?
  usuario   Usuario?      @relation(fields: [usuarioId], references: [id])
  acao      AcaoAuditoria
  recurso   String // ex: "Ata", "Contrato"
  recursoId String?
  resumo    String?
  ip        String?
  criadoEm  DateTime      @default(now())

  @@index([contaId])
  @@index([usuarioId])
  @@index([criadoEm])
}

// ============================================================
// PAGAMENTO / ASSINATURA
// ============================================================

enum FormaPagamento {
  CARTAO_CREDITO
  PIX
  BOLETO
  TRANSFERENCIA_BANCARIA
}

enum StatusCobranca {
  PENDENTE // criada, aguardando pagamento
  PROCESSANDO // em retentativa de cartão
  PAGA // confirmada
  ATRASADA // venceu sem pagamento
  CANCELADA
  ESTORNADA
}

model Cobranca {
  id      String @id @default(cuid())
  contaId String
  conta   Conta  @relation(fields: [contaId], references: [id], onDelete: Cascade)

  competencia String // YYYY-MM
  plano       Plano
  forma       FormaPagamento
  valor       Float
  status      StatusCobranca @default(PENDENTE)

  vencimento DateTime
  pagaEm     DateTime?
  tentativas Int       @default(0)

  // IDs no gateway
  gatewayChargeId   String? // ID da cobrança no ASAAS/Stripe
  gatewayInvoiceUrl String? // link pra fatura/boleto/QR PIX
  pixQrCode         String? // base64 do QR
  pixCopiaCola      String? // string PIX copia e cola
  boletoUrl         String? // URL do boleto

  observacoes  String?
  criadaEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  // Nota Fiscal de Servico (Regina 03/07): emitida automaticamente pelo
  // Asaas quando a cobranca vira PAGA (config no dashboard Asaas). Sistema
  // recebe webhook INVOICE_CREATED/SYNCHRONIZED e grava aqui.
  nfseId        String?
  nfseNumero    String?
  nfseStatus    String? // ISSUED, SYNCHRONIZED, CANCELED, ERROR
  nfsePdfUrl    String?
  nfseXmlUrl    String?
  nfseEmitidaEm DateTime?

  eventos EventoGateway[]

  @@index([contaId])
  @@index([status])
  @@index([vencimento])
}

model MetodoPagamento {
  id      String @id @default(cuid())
  contaId String
  conta   Conta  @relation(fields: [contaId], references: [id], onDelete: Cascade)

  forma   FormaPagamento
  apelido String? // ex: "Cartão Itaú final 1234"

  // Cartão (NUNCA armazenar PAN — só os 4 últimos dígitos e bandeira)
  bandeira       String?
  ultimosDigitos String?
  validadeMes    Int?
  validadeAno    Int?

  // Token do gateway (referência segura, sem dados sensíveis)
  gatewayTokenId String?

  padrao   Boolean  @default(false)
  ativo    Boolean  @default(true)
  criadoEm DateTime @default(now())

  @@index([contaId])
}

model EventoGateway {
  id         String          @id @default(cuid())
  cobrancaId String?
  cobranca   Cobranca?       @relation(fields: [cobrancaId], references: [id], onDelete: Cascade)
  provider   GatewayProvider
  evento     String // ex: "PAYMENT_CONFIRMED", "PAYMENT_OVERDUE"
  payload    String // JSON serializado
  recebidoEm DateTime        @default(now())

  @@index([cobrancaId])
  @@index([evento])
}

// ============================================================
// NOTIFICAÇÕES INTERNAS DO SISTEMA (sininho + central)
// ============================================================

enum TipoNotificacaoSistema {
  PRAZO_PROXIMO // execução com data de execução/pagamento próxima
  STATUS_PAGO // execução mudou pra PAGO (analista é avisado)
  NOVA_EXECUCAO // empresa cadastrou nova execução em contrato vinculado ao analista
  VINCULO_CRIADO // empresa vinculou um analista
  VINCULO_ENCERRADO
  COMISSAO_DISPONIVEL // valor a receber consolidado mensal
  AVISO_VENCIMENTO_FATURA // assinatura SaaS vencendo
  NOVO_INDICADO // Regina 16/07: alguem se cadastrou pelo link ?ref do EMBAIXADOR (nao confundir com VINCULO_CRIADO que e do ANALISTA)
}

model NotificacaoSistema {
  id          String                 @id @default(cuid())
  usuarioId   String // destinatário
  usuario     Usuario                @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  tipo        TipoNotificacaoSistema
  titulo      String
  descricao   String?
  link        String? // rota interna (ex: "/execucao/abc123")
  recursoTipo String? // ex: "Empenho", "VinculoAnalista"
  recursoId   String?
  lida        Boolean                @default(false)
  lidaEm      DateTime?
  criadoEm    DateTime               @default(now())

  @@index([usuarioId, lida])
  @@index([criadoEm])
}

// Chamado de suporte (Regina 14/07). Cliente abre via botao flutuante, a
// IA classifica + tenta responder direto. Casos que exigem alteracao de
// codigo/estrutura sao escalados pra admin. Casos operacionais simples
// a IA pode agir com ferramenta (opt-in WA, corrigir valor de item, etc)
// gravando auditoria.
enum CategoriaChamado {
  DUVIDA_USO // "como fazer X?"
  AJUSTE_DADOS // "trocar meu WA", "meu PIX ta errado"
  CORRECAO_OPERACIONAL // "valor unit dessa ata ta errado, o certo eh Y"
  BUG_SISTEMA // "clico e nao acontece nada"
  FEATURE_PEDIDO // "queria que tivesse tela X"
  OUTRO
}

enum StatusChamado {
  ABERTO
  IA_ANALISANDO
  IA_RESOLVEU // IA respondeu/executou — cliente confirmou
  AGUARDANDO_ADMIN // escalado, aguarda validacao Regina/Igor
  EM_IMPLEMENTACAO // admin aprovou, dev/IA vai implementar
  RESOLVIDO_ADMIN
  RECUSADO
}

model ChamadoSuporte {
  id             String            @id @default(cuid())
  contaId        String
  conta          Conta             @relation(fields: [contaId], references: [id], onDelete: Cascade)
  usuarioId      String
  usuario        Usuario           @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  categoria      CategoriaChamado  @default(OUTRO)
  titulo         String
  descricao      String
  status         StatusChamado     @default(ABERTO)
  // Resposta da IA (quando resolveu na hora ou explicou algo)
  respostaIA     String?
  iaAgiu         Boolean           @default(false)
  iaAcaoResumo   String? // "atualizou opt-in WA para false"
  // Admin que validou/resolveu
  resolvidoPorId String?
  resolvidoEm    DateTime?
  // Trilha do chamado (respostas seguintes do cliente ou admin)
  mensagens      MensagemChamado[]
  criadoEm       DateTime          @default(now())
  atualizadoEm   DateTime          @updatedAt

  @@index([status])
  @@index([contaId])
  @@index([criadoEm])
}

model MensagemChamado {
  id        String         @id @default(cuid())
  chamadoId String
  chamado   ChamadoSuporte @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  autor     String // "CLIENTE" | "IA" | "ADMIN"
  autorId   String? // usuarioId quando CLIENTE/ADMIN
  conteudo  String
  criadoEm  DateTime       @default(now())

  @@index([chamadoId])
}

// Configuração singleton (1 linha por instalação) das credenciais do gateway
model ConfiguracaoGateway {
  id            String          @id @default("singleton")
  provider      GatewayProvider @default(DEMO)
  ambiente      String          @default("sandbox") // sandbox | production
  apiKey        String? // criptografada em produção
  webhookToken  String? // valida POSTs do gateway
  atualizadoEm  DateTime        @updatedAt
  atualizadoPor String?
}

// ============================================================
// CONCILIAÇÃO BANCÁRIA (Regina 21/07/2026)
// Feature INTERMEDIARIO+PREMIUM. Cliente sobe PDF do extrato via web OU
// responde WhatsApp com anexo. LLM extrai transacoes -> matcheia com
// empenhos abertos por (valor, data, orgao, cnpj) -> gera dashboard.
// ============================================================

enum FonteExtrato {
  WEB_UPLOAD // dropzone em /conciliacao
  WHATSAPP_INBOUND // cliente respondeu lembrete anexando PDF
  MANUAL_ADMIN // super admin subiu pra testar
}

enum StatusProcessamentoExtrato {
  RECEBIDO // arquivo salvo, aguardando extracao LLM
  EXTRAINDO // LLM rodando
  EXTRAIDO // transacoes prontas, aguardando match
  CONCILIANDO // matching em andamento
  CONCLUIDO // dashboard pronto pra visualizar
  ERRO // falha na extracao ou match
}

// 1 upload = 1 Extrato. hashArquivo evita reprocessar o mesmo PDF 2x.
model Extrato {
  id              String                     @id @default(cuid())
  contaId         String
  conta           Conta                      @relation(fields: [contaId], references: [id], onDelete: Cascade)
  fonte           FonteExtrato
  status          StatusProcessamentoExtrato @default(RECEBIDO)
  // SHA-256 do PDF - dedup: se mesmo arquivo for reenviado, retorna o Extrato existente
  hashArquivo     String
  nomeArquivo     String
  tamanhoBytes    Int
  urlArquivo      String? // Vercel Blob (opcional — pode expirar)
  // Metadados extraidos pelo LLM
  bancoDetectado  String? // nome livre do banco (ex: "Banco do Brasil")
  agenciaConta    String? // ex: "1234-5 / 67890-1"
  periodoInicio   DateTime?
  periodoFim      DateTime?
  saldoInicial    Float?
  saldoFinal      Float?
  // Estatisticas pos-processamento
  totalTransacoes Int                        @default(0)
  totalCreditos   Float                      @default(0)
  totalDebitos    Float                      @default(0)
  qtdMatchAlto    Int                        @default(0) // >85% score
  qtdMatchMedio   Int                        @default(0) // 50-85%
  qtdSemMatch     Int                        @default(0)
  erroMsg         String? // se status=ERRO
  criadoEm        DateTime                   @default(now())
  atualizadoEm    DateTime                   @updatedAt

  transacoes TransacaoExtrato[]

  @@unique([contaId, hashArquivo])
  @@index([contaId, status])
}

enum TipoTransacao {
  CREDITO
  DEBITO
}

// Uma linha do extrato bancário.
model TransacaoExtrato {
  id                    String        @id @default(cuid())
  extratoId             String
  extrato               Extrato       @relation(fields: [extratoId], references: [id], onDelete: Cascade)
  tipo                  TipoTransacao
  data                  DateTime
  valor                 Float // sempre positivo; sinal vem do tipo
  descricao             String // histórico bancário bruto
  nomeContraparte       String? // nome pagador/recebedor (se identificável)
  cnpjContraparte       String? // CNPJ se aparecer no histórico
  identificadorBancario String? // nº lançamento / ID do banco (pra dedup interna)
  // Match: 0..1 conciliação vinculada. Uma transação pode conciliar com no
  // máximo 1 empenho (se casar com 2, cliente escolhe qual manualmente).
  conciliacoes          Conciliacao[]
  criadoEm              DateTime      @default(now())

  @@index([extratoId, tipo])
}

enum StatusConciliacao {
  SUGERIDA // score baixo/medio, aguarda aceite do cliente
  CONFIRMADA // cliente aceitou OU score foi >85% (auto)
  REJEITADA // cliente rejeitou match
}

// Vínculo entre transação bancária e empenho. Um empenho pode ter várias
// conciliações (parcelamento). Uma transação idealmente casa com 1 empenho.
model Conciliacao {
  id              String            @id @default(cuid())
  transacaoId     String
  transacao       TransacaoExtrato  @relation(fields: [transacaoId], references: [id], onDelete: Cascade)
  empenhoId       String
  score           Float // 0..100, calculado pelo motor de match
  fatoresMatch    Json? // {valorExato:true, datasDif:2, orgaoIgual:true, cnpjIgual:false}
  status          StatusConciliacao @default(SUGERIDA)
  confirmadaEm    DateTime?
  confirmadaPorId String? // usuarioId
  criadoEm        DateTime          @default(now())

  @@index([transacaoId])
  @@index([empenhoId])
}

// Alerta de login em dispositivo novo (Regina 22/07 — SEG P1).
// Cada usuario tem N dispositivos conhecidos, identificados por hash SHA-256
// do user-agent. Primeiro login (silencioso) marca o device como conhecido;
// login subsequente de fingerprint NOVA dispara WA pro dono.
model DispositivoConhecido {
  id                 String   @id @default(cuid())
  usuarioId          String
  usuario            Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  fingerprint        String // sha256(user-agent). Substrings de IP nao — cliente troca de rede o tempo todo.
  ipUltimoAcesso     String?
  userAgentAmostra   String? // pra Regina/Igor auditarem em /admin
  primeiroLoginEm    DateTime @default(now())
  ultimoLoginEm      DateTime @default(now())

  @@unique([usuarioId, fingerprint])
  @@index([usuarioId])
}

// Rate limit de login (Regina 21/07 — SEG P0).
// Registra CADA tentativa (sucesso ou falha) pra:
//   1) bloquear brute force por email (5 falhas / 15min)
//   2) bloquear brute force por IP    (20 falhas / 15min)
//   3) auditoria de invasoes bem-sucedidas depois de falhas suspeitas
// Rotina de limpeza (cron): apaga registros com >30d.
model TentativaLogin {
  id        String   @id @default(cuid())
  email     String // sempre lowercase
  ip        String // remoteAddr do header x-forwarded-for
  sucesso   Boolean
  userAgent String? // pra correlacao / detectar bot
  criadoEm  DateTime @default(now())

  @@index([email, criadoEm])
  @@index([ip, criadoEm])
  @@index([criadoEm]) // pra limpeza
}
