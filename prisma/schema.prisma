// CP System — schema Prisma
// PostgreSQL em produção (Neon/Supabase) e dev. Multi-tenant: cada Conta tem 1+ Empresas e 1+ Usuários.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH / TENANCY
// ============================================================

enum TipoConta {
  EMPRESA
  ANALISTA
}

enum Plano {
  BASICO
  PREMIUM
}

enum StatusAssinatura {
  TRIAL
  ATIVA
  INADIMPLENTE
  CANCELADA
}

model Conta {
  id                String           @id @default(cuid())
  tipo              TipoConta        @default(EMPRESA)
  plano             Plano            @default(BASICO)
  statusAssinatura  StatusAssinatura @default(TRIAL)
  trialAteEm        DateTime?
  proximoVencimento DateTime?
  termosAceitosEm   DateTime?
  embaixadorId      String? // analista que indicou esta conta (programa de embaixadores SaaS — não confundir com VinculoAnalista B2G)
  // Gateway de pagamento (ASAAS por padrão)
  gatewayProvider   GatewayProvider?
  gatewayCustomerId String?          // customer_id no gateway
  gatewaySubscriptionId String?      // subscription_id no gateway
  ultimaTentativaCobranca DateTime?
  bloqueadoEm       DateTime?
  criadoEm          DateTime         @default(now())
  atualizadoEm      DateTime         @updatedAt

  usuarios       Usuario[]
  empresas       Empresa[]
  analista       Analista?
  embaixador     Analista?       @relation("ContasIndicadas", fields: [embaixadorId], references: [id])
  comissoes      Comissao[]
  logsAuditoria  LogAuditoria[]
  cobrancas      Cobranca[]
  metodosPagamento MetodoPagamento[]
  vinculosAnalista VinculoAnalista[]
}

enum GatewayProvider {
  ASAAS
  STRIPE
  DEMO   // sem gateway real, simulação local
}

enum PerfilUsuario {
  ADMIN
  OPERACIONAL
  VISUALIZADOR
}

model Usuario {
  id                String        @id @default(cuid())
  nome              String
  email             String        @unique
  senhaHash         String
  perfil            PerfilUsuario @default(ADMIN)
  superAdmin        Boolean       @default(false) // gestor da plataforma (Igor) — vê tudo
  emailVerificadoEm DateTime?
  criadoEm          DateTime      @default(now())
  atualizadoEm      DateTime      @updatedAt

  contaId String
  conta   Conta  @relation(fields: [contaId], references: [id], onDelete: Cascade)

  sessoes              Sessao[]
  logsAuditoria        LogAuditoria[]
  notificacoesSistema  NotificacaoSistema[]
  // Quem criou cada documento — base da regra "só edita criador + admin"
  atasCriadas      Ata[]      @relation("AtasCriadas")
  contratosCriados Contrato[] @relation("ContratosCriados")
  empenhosCriados  Empenho[]  @relation("EmpenhosCriados")

  @@index([contaId])
}

model Sessao {
  id        String   @id @default(cuid())
  token     String   @unique
  usuarioId String
  expiraEm  DateTime
  criadoEm  DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
}

// ============================================================
// EMPRESA (multi-CNPJ)
// ============================================================

enum PorteEmpresa {
  MEI
  ME
  EPP
  MEDIA
  GRANDE
}

model Empresa {
  id               String       @id @default(cuid())
  razaoSocial      String
  nomeFantasia     String?
  cnpj             String       @unique
  porte            PorteEmpresa
  cnaePrincipal    String?
  cnaesSecundarios String?
  naturezaJuridica String
  endereco         String
  complemento      String?
  cep              String
  email            String   // primário (legado mantido pra not break queries existentes)
  emails           String[] @default([])
  telefones        String   // primário (legado)
  telefonesLista   String[] @default([])
  responsavel      String
  criadoEm         DateTime     @default(now())
  atualizadoEm     DateTime     @updatedAt

  contaId String
  conta   Conta  @relation(fields: [contaId], references: [id], onDelete: Cascade)

  atas      Ata[]
  contratos Contrato[]
  empenhos  Empenho[]

  @@index([contaId])
}

// ============================================================
// ANALISTA + EMBAIXADORES + COMISSÕES
// ============================================================

enum TierEmbaixador {
  BRONZE   // 1-5 ativos = 3%
  PRATA    // 6-10 ativos = 4%
  OURO     // 11-15 ativos = 5%
  DIAMOND  // 15+ ativos = 6%
}

model Analista {
  id            String   @id @default(cuid())
  nomeCompleto  String
  cpf           String   @unique
  telefone      String
  endereco      String
  cep           String?
  complemento   String?
  email         String
  banco         String?
  agencia       String?
  contaCorrente String?
  pix           String?
  razaoSocial   String?
  nomeFantasia  String?
  cnpj          String?
  // Pessoa jurídica adicional (opcional — preenchido se o analista emite nota como PJ)
  porte             PorteEmpresa?
  cnaePrincipal     String?
  cnaesSecundarios  String?
  naturezaJuridica  String?
  enderecoPj        String?
  emailPj           String?
  telefonePj        String?
  divulgacaoUrl String? // link da bio com o programa
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  contaId String? @unique
  conta   Conta?  @relation(fields: [contaId], references: [id], onDelete: Cascade)

  contasIndicadas Conta[]           @relation("ContasIndicadas")
  comissoes       Comissao[]
  vinculos        VinculoAnalista[]
  comissoesExecucao ComissaoExecucao[]
}

// ============================================================
// VÍNCULO GRUPO ↔ ANALISTA (modelo B2G)
// ============================================================
// Tabela associativa que carrega os atributos do vínculo: data de início
// (regra crítica de comissionamento), percentual, fixo mensal e status.
// O analista comissiona apenas execuções com criadoEm >= dataInicio.
//
// Hoje ainda existe Conta.embaixadorId pra modelo de embaixador SaaS;
// ambos coexistem (são comissões de naturezas diferentes).

enum StatusVinculoAnalista {
  ATIVO
  ENCERRADO
}

model VinculoAnalista {
  id                  String                @id @default(cuid())
  contaId             String
  conta               Conta                 @relation(fields: [contaId], references: [id], onDelete: Cascade)
  analistaId          String
  analista            Analista              @relation(fields: [analistaId], references: [id], onDelete: Cascade)

  dataInicio          DateTime              @default(now())
  percentualComissao  Float                 @default(0)
  fixoMensal          Float                 @default(0)
  diaVencimentoFixo   Int                   @default(5)
  status              StatusVinculoAnalista @default(ATIVO)
  encerradoEm         DateTime?
  observacoes         String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  fixosPagos        PagamentoFixoMensal[]
  comissoesExecucao ComissaoExecucao[]

  @@unique([contaId, analistaId, dataInicio])
  @@index([contaId])
  @@index([analistaId])
  @@index([status])
}

// Status da comissão fixa mensal. Mesmo conceito da Linha B variável, mas
// sem o estado AGUARDANDO_ORGAO (o fixo independe do pagamento do órgão).
enum StatusComissaoFixa {
  A_RECEBER
  ATRASADO
  PAGO
  PAGO_PARCIAL
}

// Histórico de pagamentos do fixo mensal (por competência).
// Uma linha por VinculoAnalista × competência (YYYY-MM). Geradas automaticamente
// pelo cron diário na primeira passagem após a virada do mês.
model PagamentoFixoMensal {
  id          String          @id @default(cuid())
  vinculoId   String
  vinculo     VinculoAnalista @relation(fields: [vinculoId], references: [id], onDelete: Cascade)
  competencia String          // YYYY-MM
  valor       Float
  // Vencimento por linha (editável) — snapshot de diaVencimentoFixo no momento
  // da criação. Mudanças posteriores no vínculo não afetam linhas já geradas.
  vencimento  DateTime?
  status         StatusComissaoFixa @default(A_RECEBER)
  valorRecebido  Float              @default(0)
  comprovanteUrl String?
  // Campos legados — mantidos pra compatibilidade. `paga` espelha status === PAGO.
  paga        Boolean         @default(false)
  pagaEm      DateTime?
  observacoes String?
  criadoEm    DateTime        @default(now())
  atualizadoEm DateTime       @updatedAt @default(now())

  @@unique([vinculoId, competencia])
  @@index([vinculoId])
  @@index([status])
}

model Comissao {
  id           String         @id @default(cuid())
  analistaId   String
  contaId      String
  competencia  String         // YYYY-MM
  valorBase    Float          // MRR da conta
  tier         TierEmbaixador
  percentual   Float          // 3, 4, 5 ou 6
  valor        Float
  paga         Boolean        @default(false)
  pagaEm       DateTime?
  criadoEm     DateTime       @default(now())

  analista Analista @relation(fields: [analistaId], references: [id], onDelete: Cascade)
  conta    Conta    @relation(fields: [contaId], references: [id], onDelete: Cascade)

  @@unique([analistaId, contaId, competencia])
  @@index([analistaId])
  @@index([contaId])
}

// ============================================================
// CONTRATAÇÕES
// ============================================================

enum TipoObjeto {
  FORNECIMENTO
  FORNECIMENTO_CONTINUO
  SERVICOS
  SERVICOS_CONTINUOS
  SERVICOS_DEDICACAO_EXCLUSIVA
  LOCACAO
  OBRAS_ENGENHARIA
}

// Modalidade de entrega do contrato (Lei 14.133 — fluxograma do contrato não-continuado).
// INTEGRAL = todo o quantitativo de uma vez.
// PARCELADA = lotes com prazos distintos (ver ParcelaContrato).
// SOB_DEMANDA = quantidade estimativa, sem cronograma fixo (cada empenho/AF puxa do saldo).
enum ModalidadeEntrega {
  INTEGRAL
  PARCELADA
  SOB_DEMANDA
}

// Unidade em que o prazo de entrega/execução é expresso. Default DIAS pra
// retrocompat com registros antigos (todos cadastrados como dias até aqui).
enum PrazoEntregaUnidade {
  DIAS
  MESES
}

// Modo de inclusão do prazo de entrega. RELATIVO = qtd+unidade contada a
// partir do pedido (típico de Fornecimento). DATA_CERTA = data fixa de
// execução (típico de Locação para evento). Por enquanto só Contrato usa
// — Ata e Empenho seguem só RELATIVO.
enum PrazoEntregaModo {
  RELATIVO
  DATA_CERTA
}

// Marco a partir do qual conta o prazo de entrega.
// O contrato define qual é (Lei 14.133 — fluxograma do contrato não-continuado).
enum MarcoInicialPrazoEntrega {
  ASSINATURA_CONTRATO
  ORDEM_FORNECIMENTO
  OUTRO
}

enum ProcedimentoSelecao {
  PREGAO_ELETRONICO
  PREGAO_ELETRONICO_INTERNACIONAL
  PREGAO_PRESENCIAL
  CONCORRENCIA
  CONCURSO
  LEILAO
  DIALOGO_COMPETITIVO
  DISPENSA
  INEXIGIBILIDADE
}

enum Moeda {
  BRL
  USD
  EUR
}

enum TipoOrgaoNaAta {
  GERENCIADOR
  PARTICIPANTE
  CARONA
}

enum FuncaoPontoFocal {
  GESTOR
  FISCAL_TECNICO
  FISCAL_ADMINISTRATIVO
  RESPONSAVEL_SETOR
  CONTATO_GERAL
  AUTORIDADE_COMPETENTE
  FISCAL
  OUTRO
}

enum MarcoReajusteOrigem {
  ORCAMENTO_ESTIMADO
  ASSINATURA
  OMISSA
}

model Ata {
  id                     String              @id @default(cuid())
  tipo                   TipoObjeto
  numero                 String
  processoAdministrativo String
  procedimentoSelecao    ProcedimentoSelecao
  numeroLicitacao        String?

  // Órgão GERENCIADOR (sempre 1, snapshot legado pra compatibilidade)
  orgaoNome      String
  orgaoCnpj      String
  orgaoEndereco  String
  orgaoEmail     String?
  orgaoTelefone  String?

  objeto                 String
  dataAssinatura         DateTime
  dataPublicacao         DateTime?
  vigenciaInicio         DateTime
  vigenciaFim            DateTime
  prazoEntregaDias       Int?
  prazoEntregaUnidade    PrazoEntregaUnidade @default(DIAS)
  prazoEntregaNaoAplica  Boolean   @default(false)
  prazoPagamentoDias     Int?
  marcoOrcamentoEstimado DateTime?
  // Origem do marco de reajuste (briefing PDF — Cadastro Ata 2.4)
  marcoReajusteOrigem    MarcoReajusteOrigem?

  aceitaCarona  Boolean @default(false)
  idAtaPncp     String?
  arquivoPdfUrl String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  // Quem criou — null em registros legados (preexistentes à feature).
  // Regra de edição: criador OU usuário ADMIN/superAdmin da conta. Registros
  // legados ficam restritos a ADMIN/superAdmin.
  criadoPorId String?
  criadoPor   Usuario? @relation("AtasCriadas", fields: [criadoPorId], references: [id])

  itens                AtaItem[]
  contratos             Contrato[]
  empenhos              Empenho[]
  orgaos                OrgaoNaAta[]
  enderecosEntrega      EnderecoEntrega[]
  pontosFocais          PontoFocal[]
  notificacoes          Notificacao[]
  procedimentos         ProcedimentoApuratorio[]
  anexos                Anexo[]
  anotacoes             Anotacao[]
  termosAditivos        TermoAditivo[]
  apostilamentos        Apostilamento[]

  @@index([empresaId])
  @@index([criadoPorId])
}

model AtaItem {
  id            String  @id @default(cuid())
  descricao     String
  unidade       String
  quantidade    Float
  marca         String?
  valorUnitario Float
  valorTotal    Float
  moeda         Moeda   @default(BRL)
  // Lote (briefing PDF — Cadastro Ata 2.7: itens agrupados em lotes)
  lote          String?
  // Número do item dentro do lote (ou global se isolado). Texto livre pra
  // permitir "01", "1.A", etc. Validação de unicidade Lote+numero é feita
  // na action de criação (não constraint do banco).
  numero        String?

  ataId String
  ata   Ata    @relation(fields: [ataId], references: [id], onDelete: Cascade)

  contratoItens ContratoItem[]
  empenhoItens  EmpenhoItem[]

  @@index([ataId])
}

model OrgaoNaAta {
  id            String         @id @default(cuid())
  ataId         String
  ata           Ata            @relation(fields: [ataId], references: [id], onDelete: Cascade)
  tipo          TipoOrgaoNaAta
  nome          String
  cnpj          String
  endereco      String
  email         String?
  telefone      String?
  // Carona: limites de adesão
  limiteValor   Float?         // valor monetário máximo permitido a esse carona
  limitePct     Float?         // % do total da Ata (default sistema: 50% por órgão)

  enderecosEntrega EnderecoEntrega[]
  pontosFocais     PontoFocal[]

  @@index([ataId])
}

model EnderecoEntrega {
  id        String  @id @default(cuid())
  rotulo    String?
  endereco  String
  ataId     String?
  ata       Ata?    @relation(fields: [ataId], references: [id], onDelete: Cascade)
  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  empenhoId  String?
  empenho    Empenho?  @relation(fields: [empenhoId], references: [id], onDelete: Cascade)
  orgaoNaAtaId String?
  orgaoNaAta   OrgaoNaAta? @relation(fields: [orgaoNaAtaId], references: [id], onDelete: Cascade)

  @@index([ataId])
  @@index([contratoId])
  @@index([empenhoId])
  @@index([orgaoNaAtaId])
}

model PontoFocal {
  id        String           @id @default(cuid())
  funcao    FuncaoPontoFocal
  // Descrição livre quando funcao = OUTRO (briefing PDF — Cadastro Ata 2.6)
  funcaoDescricao String?
  nome      String
  email     String?
  telefone  String?
  ataId     String?
  ata       Ata?             @relation(fields: [ataId], references: [id], onDelete: Cascade)
  contratoId String?
  contrato   Contrato?       @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  empenhoId  String?
  empenho    Empenho?        @relation(fields: [empenhoId], references: [id], onDelete: Cascade)
  orgaoNaAtaId String?
  orgaoNaAta   OrgaoNaAta?   @relation(fields: [orgaoNaAtaId], references: [id], onDelete: Cascade)

  @@index([ataId])
  @@index([contratoId])
  @@index([empenhoId])
  @@index([orgaoNaAtaId])
}

model Contrato {
  id                     String              @id @default(cuid())
  tipo                   TipoObjeto
  numero                 String
  numeroNotaEmpenho      String?
  processoAdministrativo String
  procedimentoSelecao    ProcedimentoSelecao
  numeroLicitacao        String?

  orgaoNome      String
  orgaoCnpj      String
  orgaoEndereco  String
  orgaoEmail     String?
  orgaoTelefone  String?

  objeto                 String
  dataAssinatura         DateTime
  dataPublicacao         DateTime?
  vigenciaInicio         DateTime
  vigenciaFim            DateTime
  prazoEntregaDias       Int?
  prazoEntregaUnidade    PrazoEntregaUnidade @default(DIAS)
  // Modo de prazo de entrega: RELATIVO usa qtd+unidade (prazoEntregaDias),
  // DATA_CERTA usa dataEntregaCerta (ex.: locação de evento com data fixa).
  prazoEntregaModo       PrazoEntregaModo    @default(RELATIVO)
  dataEntregaCerta       DateTime?
  prazoPagamentoDias     Int?
  marcoOrcamentoEstimado DateTime?
  marcoReajusteOrigem    MarcoReajusteOrigem?

  // Fluxograma da contratação — Lei 14.133 (contratos não-continuados):
  // como o quantitativo é entregue e qual o marco inicial do prazo.
  modalidadeEntrega     ModalidadeEntrega         @default(INTEGRAL)
  marcoInicialPrazo     MarcoInicialPrazoEntrega? // null quando SOB_DEMANDA (não há prazo único)
  marcoInicialDescricao String?                   // só preenchido quando marcoInicialPrazo = OUTRO

  // M5 Garantia — tri-estado: null = não declarado, true = há previsão,
  // false = explicitamente sem previsão (usuário marcou "Não" e salvou).
  temGarantia Boolean?

  // Documentos de suporte do contrato (Lei 14.133)
  numeroOrdemFornecimento String? // ex: "OF 042/2024" — quando o órgão emite OF/AF
  arquivoOfUrl            String?

  arquivoPdfUrl String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  ataId String?
  ata   Ata?    @relation(fields: [ataId], references: [id])

  criadoPorId String?
  criadoPor   Usuario? @relation("ContratosCriados", fields: [criadoPorId], references: [id])

  itens             ContratoItem[]
  parcelas          ParcelaContrato[]
  empenhos          Empenho[]
  enderecosEntrega  EnderecoEntrega[]
  pontosFocais      PontoFocal[]
  termosAditivos    TermoAditivo[]
  apostilamentos    Apostilamento[]
  reajustes         Reajuste[]
  notificacoes      Notificacao[]
  procedimentos     ProcedimentoApuratorio[]
  garantias         Garantia[]
  anexos            Anexo[]
  anotacoes         Anotacao[]

  @@index([empresaId])
  @@index([ataId])
  @@index([criadoPorId])
}

// Cronograma de entrega quando modalidadeEntrega = PARCELADA.
// Cada parcela tem seu próprio prazo (em dias após o marco inicial) e descrição.
model ParcelaContrato {
  id            String   @id @default(cuid())
  numero        Int
  prazoDias     Int      // dias após o marco inicial do contrato
  descricao     String?  // ex: "primeiros 50 computadores DELL Inspiron"
  valorEstimado Float?
  criadoEm      DateTime @default(now())

  contratoId String
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@unique([contratoId, numero])
  @@index([contratoId])
}

model ContratoItem {
  id            String  @id @default(cuid())
  descricao     String
  unidade       String
  quantidade    Float
  marca         String?
  valorUnitario Float
  valorTotal    Float
  moeda         Moeda   @default(BRL)

  contratoId String
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  ataItemId String?
  ataItem   AtaItem? @relation(fields: [ataItemId], references: [id])

  @@index([contratoId])
  @@index([ataItemId])
}

enum StatusExecucao {
  EMPENHADO
  PEDIDO_RECEBIDO
  EM_TRANSITO
  ENTREGUE
  NF_EMITIDA
  NF_ENCAMINHADA
  PAGO
}

// Instrumentos contratuais substitutivos do Termo de Contrato (art. 95,
// Lei 14.133/2021). Todos compartilham o mesmo model Empenho — o campo
// `instrumento` diferencia a natureza jurídica e dispara labels/campos
// específicos no formulário.
enum InstrumentoContratual {
  NOTA_EMPENHO
  CARTA_CONTRATO
  AUTORIZACAO_COMPRA
  AUTORIZACAO_ENTREGA
  ORDEM_SERVICO
}

// ============================================================
// COMISSÃO POR EXECUÇÃO (Linha B — empresa paga analista)
// ============================================================
// Distinção crítica versus Empenho.status === "PAGO":
//   - Empenho.status PAGO = órgão pagou a empresa (Linha A, sem efeito caixa
//     pro analista)
//   - ComissaoExecucao.status PAGO = empresa pagou a comissão ao analista
//     (Linha B, é o que entra no painel "Recebido no mês")
//
// Bug histórico: o sistema considerava Linha A como Linha B, marcando comissão
// como recebida automaticamente. Hoje os dois fluxos são independentes.
enum StatusComissaoExecucao {
  AGUARDANDO_ORGAO  // Empenho ainda não foi pago pelo órgão à empresa
  A_RECEBER         // Órgão pagou; comissão liberada para cobrança pelo analista
  ATRASADO          // A_RECEBER e passou da data combinada (controle do analista)
  PAGO              // Empresa pagou a comissão ao analista
  PAGO_PARCIAL      // Empresa pagou parcialmente a comissão
}

model ComissaoExecucao {
  id        String  @id @default(cuid())
  empenhoId String
  empenho   Empenho @relation(fields: [empenhoId], references: [id], onDelete: Cascade)

  vinculoId String
  vinculo   VinculoAnalista @relation(fields: [vinculoId], references: [id], onDelete: Cascade)

  analistaId String
  analista   Analista @relation(fields: [analistaId], references: [id], onDelete: Cascade)

  // Snapshot do percentual no momento da criação — protege contra alterações
  // retroativas no vínculo. Quando o admin muda o % no cadastro, vale só pra
  // execuções futuras.
  percentual         Float
  percentualOverride Boolean @default(false) // se foi editado por execução
  observacaoOverride String?

  // Valores monetários
  valorBaseEmpenho Float           // snapshot do total empenhado (sem alterações)
  valorBasePago    Float  @default(0) // quanto o órgão efetivamente pagou (Linha A)
  valorCalculado   Float           // percentual × valorBasePago (a comissão devida)
  valorRecebido    Float  @default(0) // quanto o analista já recebeu da empresa

  status         StatusComissaoExecucao @default(AGUARDANDO_ORGAO)
  dataPagamento  DateTime?
  comprovanteUrl String?
  observacao     String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([empenhoId, vinculoId])
  @@index([analistaId, status])
  @@index([vinculoId])
  @@index([empenhoId])
}

model Empenho {
  id                     String              @id @default(cuid())
  tipo                   TipoObjeto
  // Natureza jurídica do registro (art. 95, Lei 14.133/2021). Default cobre
  // legado: empenhos cadastrados antes da feature continuam aparecendo como
  // "Nota de Empenho" sem regressão.
  instrumento            InstrumentoContratual @default(NOTA_EMPENHO)
  numero                 String
  identificador          String?             // ex: "1ª parcela", "Solicitação 042/2026"
  processoAdministrativo String
  // Opcional pro Empenho (M3.3, decisão Igor): info redundante quando o
  // Empenho deriva de Ata/Contrato. Continua obrigatório em Ata/Contrato.
  procedimentoSelecao    ProcedimentoSelecao?
  numeroLicitacao        String?

  // Campos específicos por instrumento (todos opcionais — só preenchidos
  // quando o instrumento correspondente exige).
  classificacaoOrcamentaria String?        // Nota de Empenho
  signatario                String?        // Carta-Contrato
  dataAssinatura            DateTime?      // Carta-Contrato
  departamentoEmissor       String?        // Autorização de Compra
  pontoColeta               String?        // Autorização de Entrega (origem)
  contatoRecebedor          String?        // Autorização de Entrega (nome/contato)
  fiscalResponsavel         String?        // Ordem de Execução de Serviço

  // M5 Garantia — tri-estado igual ao Contrato.
  temGarantia               Boolean?

  orgaoNome      String
  orgaoCnpj      String
  orgaoEndereco  String
  orgaoEmail     String?
  orgaoTelefone  String?

  objeto                  String
  dataEmissao             DateTime
  dataPrevistaExecucao    DateTime?           // pra alerta de prazo no painel do analista
  dataPrevistaPagamento   DateTime?
  vigenciaInicio          DateTime
  vigenciaFim             DateTime
  prazoEntregaDias        Int?
  prazoEntregaUnidade     PrazoEntregaUnidade @default(DIAS)
  // Módulo 3.3 — modo do prazo: relativo (qtd+unidade) ou data fixa.
  // Mesmo enum compartilhado com Contrato (PrazoEntregaModo).
  prazoEntregaModo        PrazoEntregaModo    @default(RELATIVO)
  dataEntregaCerta        DateTime?
  prazoPagamentoDias      Int?

  status StatusExecucao @default(EMPENHADO)

  dataPedidoRecebido      DateTime?
  arquivoPedidoRecebido   String?
  dataDespacho            DateTime?
  arquivoDespacho         String?
  dataEntrega             DateTime?
  arquivoEntrega          String?
  dataNfEmitida           DateTime?
  arquivoNfEmitida        String?
  dataNfEncaminhada       DateTime?
  arquivoNfEncaminhada    String?
  dataPagamento           DateTime?
  arquivoPagamento        String?

  // Ordem de Fornecimento/Execução
  numeroOrdemFornecimento String?
  arquivoOfUrl            String?

  arquivoPdfUrl String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  ataId String?
  ata   Ata?    @relation(fields: [ataId], references: [id])

  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id])

  criadoPorId String?
  criadoPor   Usuario? @relation("EmpenhosCriados", fields: [criadoPorId], references: [id])

  itens             EmpenhoItem[]
  enderecosEntrega  EnderecoEntrega[]
  pontosFocais      PontoFocal[]
  termosAditivos    TermoAditivo[]
  apostilamentos    Apostilamento[]
  reajustes         Reajuste[]
  notificacoes      Notificacao[]
  procedimentos     ProcedimentoApuratorio[]
  garantias         Garantia[]
  anexos            Anexo[]
  anotacoes         Anotacao[]
  comissoes         ComissaoExecucao[]

  @@index([empresaId])
  @@index([ataId])
  @@index([contratoId])
  @@index([criadoPorId])
}

model EmpenhoItem {
  id            String  @id @default(cuid())
  descricao     String
  unidade       String
  quantidade    Float
  marca         String?
  valorUnitario Float
  valorTotal    Float
  moeda         Moeda   @default(BRL)

  empenhoId String
  empenho   Empenho @relation(fields: [empenhoId], references: [id], onDelete: Cascade)

  ataItemId String?
  ataItem   AtaItem? @relation(fields: [ataItemId], references: [id])

  @@index([empenhoId])
  @@index([ataItemId])
}

// ============================================================
// ALTERAÇÕES CONTRATUAIS (aditivos, apostilamentos, reajustes)
// ============================================================

enum NaturezaAlteracao {
  VALOR
  PRAZO_VIGENCIA
  PRAZO_ENTREGA
  ESCOPO
  REAJUSTE
  REEQUILIBRIO
  OUTRO
}

model TermoAditivo {
  id              String              @id @default(cuid())
  numero          String
  objeto          String
  dataAssinatura  DateTime
  natureza        String              // CSV de NaturezaAlteracao
  alteraValor     Boolean             @default(false)
  novoValor       Float?
  alteraPrazoVigencia Boolean         @default(false)
  novaVigenciaFim DateTime?
  alteraPrazoEntrega Boolean          @default(false)
  novoPrazoEntregaDias Int?
  observacoes     String?
  arquivoPdfUrl   String?
  criadoEm        DateTime            @default(now())

  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  empenhoId  String?
  empenho    Empenho?  @relation(fields: [empenhoId], references: [id], onDelete: Cascade)
  ataId      String?
  ata        Ata?      @relation(fields: [ataId], references: [id], onDelete: Cascade)

  @@index([contratoId])
  @@index([empenhoId])
  @@index([ataId])
}

model Apostilamento {
  id                  String   @id @default(cuid())
  numero              String
  objeto              String
  dataAssinatura      DateTime
  natureza            String
  alteraValor         Boolean  @default(false)
  novoValor           Float?
  alteraPrazoVigencia Boolean  @default(false)
  novaVigenciaFim     DateTime?
  alteraPrazoEntrega  Boolean  @default(false)
  novoPrazoEntregaDias Int?
  observacoes         String?
  arquivoPdfUrl       String?
  criadoEm            DateTime @default(now())

  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  empenhoId  String?
  empenho    Empenho?  @relation(fields: [empenhoId], references: [id], onDelete: Cascade)
  ataId      String?
  ata        Ata?      @relation(fields: [ataId], references: [id], onDelete: Cascade)

  @@index([contratoId])
  @@index([empenhoId])
  @@index([ataId])
}

enum InstrumentoReajuste {
  TERMO_ADITIVO
  APOSTILAMENTO
}

enum IndiceReajuste {
  IPCA
  IGPM
  INCC
  INPC
  CONTRATUAL
  OUTRO
}

model Reajuste {
  id                String              @id @default(cuid())
  dataPedido        DateTime
  dataAprovacao     DateTime?
  indice            IndiceReajuste
  percentual        Float
  valorAnterior     Float
  valorNovo         Float
  instrumento       InstrumentoReajuste
  instrumentoNumero String?
  observacoes       String?
  criadoEm          DateTime            @default(now())

  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  empenhoId  String?
  empenho    Empenho?  @relation(fields: [empenhoId], references: [id], onDelete: Cascade)

  @@index([contratoId])
  @@index([empenhoId])
}

// ============================================================
// NOTIFICAÇÕES ADMINISTRATIVAS
// ============================================================

enum StatusNotificacao {
  RECEBIDA
  EM_TRATATIVA
  RESPONDIDA
  FINALIZADA
}

model Notificacao {
  id             String            @id @default(cuid())
  numero         String?
  assunto        String
  descricao      String
  dataRecebimento DateTime
  prazoResposta  Int?              // dias
  status         StatusNotificacao @default(RECEBIDA)
  arquivoPdfUrl  String?
  criadoEm       DateTime          @default(now())
  atualizadoEm   DateTime          @updatedAt

  ataId      String?
  ata        Ata?      @relation(fields: [ataId], references: [id], onDelete: Cascade)
  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  empenhoId  String?
  empenho    Empenho?  @relation(fields: [empenhoId], references: [id], onDelete: Cascade)

  andamentos AndamentoNotificacao[]

  @@index([ataId])
  @@index([contratoId])
  @@index([empenhoId])
}

model AndamentoNotificacao {
  id            String            @id @default(cuid())
  notificacaoId String
  notificacao   Notificacao       @relation(fields: [notificacaoId], references: [id], onDelete: Cascade)
  status        StatusNotificacao
  descricao     String
  dataEvento    DateTime
  criadoEm      DateTime          @default(now())

  @@index([notificacaoId])
}

// ============================================================
// PROCEDIMENTOS APURATÓRIOS (Lei 14.133/2021 art. 157+)
// ============================================================

enum FaseProcedimento {
  ABERTURA
  NOTIFICACAO_DEFESA
  DEFESA_APRESENTADA
  PEDIDO_PROVAS
  DEFERIMENTO_PROVAS
  NOTIFICACAO_ALEGACOES
  ALEGACOES_FINAIS
  DECISAO_1A_INSTANCIA
  RECURSO
  DECISAO_FINAL
  ARQUIVAMENTO
  PENALIDADE_APLICADA
}

enum TipoPenalidade {
  ADVERTENCIA
  MULTA
  IMPEDIMENTO_LICITAR
  DECLARACAO_INIDONEIDADE
}

model ProcedimentoApuratorio {
  id                String   @id @default(cuid())
  numero            String?
  notificacaoNumero String?
  assunto           String
  descricao         String
  comissao          String?  // nome dos servidores da comissão
  autoridade        String?  // autoridade competente
  dataAbertura      DateTime
  prazoDefesaDias   Int      @default(15) // padrão Lei 14.133
  prazoRecursoDias  Int      @default(15)
  arquivado         Boolean  @default(false)
  arquivoPdfUrl     String?
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt

  ataId      String?
  ata        Ata?      @relation(fields: [ataId], references: [id], onDelete: Cascade)
  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  empenhoId  String?
  empenho    Empenho?  @relation(fields: [empenhoId], references: [id], onDelete: Cascade)

  andamentos  AndamentoProcedimento[]
  penalidades Penalidade[]

  @@index([ataId])
  @@index([contratoId])
  @@index([empenhoId])
}

model AndamentoProcedimento {
  id              String           @id @default(cuid())
  procedimentoId  String
  procedimento    ProcedimentoApuratorio @relation(fields: [procedimentoId], references: [id], onDelete: Cascade)
  fase            FaseProcedimento
  descricao       String
  dataEvento      DateTime
  arquivoPdfUrl   String?
  criadoEm        DateTime         @default(now())

  @@index([procedimentoId])
}

model Penalidade {
  id              String         @id @default(cuid())
  procedimentoId  String
  procedimento    ProcedimentoApuratorio @relation(fields: [procedimentoId], references: [id], onDelete: Cascade)
  tipo            TipoPenalidade
  valor           Float?         // pra multa
  duracaoMeses    Int?           // pra impedimento/inidoneidade
  fundamentacao   String?
  dataAplicacao   DateTime
  criadoEm        DateTime       @default(now())

  @@index([procedimentoId])
}

// ============================================================
// GARANTIA CONTRATUAL
// ============================================================

enum ModalidadeGarantia {
  SEGURO_GARANTIA
  FIANCA_BANCARIA
  CAUCAO_DINHEIRO
  TITULOS_DIVIDA_PUBLICA
}

model Garantia {
  id          String             @id @default(cuid())
  modalidade  ModalidadeGarantia
  // Seguro-garantia
  seguradora  String?
  // Fiança bancária
  banco       String?
  // Comum
  valor       Float
  dataInicio  DateTime
  dataFim     DateTime?
  descricao   String?            // pra títulos da dívida pública e outros
  arquivoPdfUrl String?
  criadoEm    DateTime           @default(now())
  atualizadoEm DateTime          @updatedAt

  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  empenhoId  String?
  empenho    Empenho?  @relation(fields: [empenhoId], references: [id], onDelete: Cascade)

  endossos Endosso[]

  @@index([contratoId])
  @@index([empenhoId])
}

model Endosso {
  id          String   @id @default(cuid())
  garantiaId  String
  garantia    Garantia @relation(fields: [garantiaId], references: [id], onDelete: Cascade)
  valor       Float
  dataInicio  DateTime
  dataFim     DateTime?
  observacoes String?
  arquivoPdfUrl String?
  criadoEm    DateTime @default(now())

  @@index([garantiaId])
}

// ============================================================
// ANEXOS + ANOTAÇÕES
// ============================================================

enum CategoriaAnexo {
  CONTRATUAL
  ADITIVO
  APOSTILAMENTO
  GARANTIA
  NOTIFICACAO
  PROCEDIMENTO
  NF
  COMPROVANTE
  OUTRO
}

model Anexo {
  id           String         @id @default(cuid())
  nome         String
  url          String         // path local /uploads/<id>.<ext>
  mimeType     String?
  tamanhoBytes Int?
  categoria    CategoriaAnexo @default(OUTRO)
  criadoEm     DateTime       @default(now())

  ataId      String?
  ata        Ata?      @relation(fields: [ataId], references: [id], onDelete: Cascade)
  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  empenhoId  String?
  empenho    Empenho?  @relation(fields: [empenhoId], references: [id], onDelete: Cascade)

  @@index([ataId])
  @@index([contratoId])
  @@index([empenhoId])
}

model Anotacao {
  id        String   @id @default(cuid())
  texto     String
  autorNome String?
  criadoEm  DateTime @default(now())

  ataId      String?
  ata        Ata?      @relation(fields: [ataId], references: [id], onDelete: Cascade)
  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  empenhoId  String?
  empenho    Empenho?  @relation(fields: [empenhoId], references: [id], onDelete: Cascade)

  @@index([ataId])
  @@index([contratoId])
  @@index([empenhoId])
}

// ============================================================
// LOGS DE AUDITORIA
// ============================================================

enum AcaoAuditoria {
  CRIAR
  ATUALIZAR
  EXCLUIR
  LOGIN
  LOGOUT
  EXPORTAR
  UPLOAD
  DOWNLOAD
}

// Cache de geocodificação por CNPJ. Evita bater no Nominatim toda vez que
// o dashboard carrega. Atualizado on-demand quando um órgão novo aparece
// ou quando o endereço cadastrado muda.
model OrgaoGeocode {
  cnpj         String   @id // CNPJ normalizado (só dígitos)
  endereco     String   // endereço usado pra geocodificar (audita re-trigger)
  latitude     Float
  longitude    Float
  precisao     String?  // "exact" / "city" / "state" — qualidade do resultado
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

// Cache de geocodificação para endereços de entrega (sem CNPJ associado).
// Usa o próprio endereço normalizado como chave para evitar geocodificar
// duas vezes o mesmo local. Reutiliza o mesmo pool de rate-limit do Nominatim.
model EnderecoGeocode {
  endereco     String   @id // endereço normalizado (trim, lowercase) — chave única
  latitude     Float
  longitude    Float
  precisao     String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model LogAuditoria {
  id          String        @id @default(cuid())
  contaId     String
  conta       Conta         @relation(fields: [contaId], references: [id], onDelete: Cascade)
  usuarioId   String?
  usuario     Usuario?      @relation(fields: [usuarioId], references: [id])
  acao        AcaoAuditoria
  recurso     String        // ex: "Ata", "Contrato"
  recursoId   String?
  resumo      String?
  ip          String?
  criadoEm    DateTime      @default(now())

  @@index([contaId])
  @@index([usuarioId])
  @@index([criadoEm])
}

// ============================================================
// PAGAMENTO / ASSINATURA
// ============================================================

enum FormaPagamento {
  CARTAO_CREDITO
  PIX
  BOLETO
  TRANSFERENCIA_BANCARIA
}

enum StatusCobranca {
  PENDENTE          // criada, aguardando pagamento
  PROCESSANDO       // em retentativa de cartão
  PAGA              // confirmada
  ATRASADA          // venceu sem pagamento
  CANCELADA
  ESTORNADA
}

model Cobranca {
  id                String         @id @default(cuid())
  contaId           String
  conta             Conta          @relation(fields: [contaId], references: [id], onDelete: Cascade)

  competencia       String         // YYYY-MM
  plano             Plano
  forma             FormaPagamento
  valor             Float
  status            StatusCobranca @default(PENDENTE)

  vencimento        DateTime
  pagaEm            DateTime?
  tentativas        Int            @default(0)

  // IDs no gateway
  gatewayChargeId   String?        // ID da cobrança no ASAAS/Stripe
  gatewayInvoiceUrl String?        // link pra fatura/boleto/QR PIX
  pixQrCode         String?        // base64 do QR
  pixCopiaCola      String?        // string PIX copia e cola
  boletoUrl         String?        // URL do boleto

  observacoes       String?
  criadaEm          DateTime       @default(now())
  atualizadoEm      DateTime       @updatedAt

  eventos           EventoGateway[]

  @@index([contaId])
  @@index([status])
  @@index([vencimento])
}

model MetodoPagamento {
  id                String         @id @default(cuid())
  contaId           String
  conta             Conta          @relation(fields: [contaId], references: [id], onDelete: Cascade)

  forma             FormaPagamento
  apelido           String?        // ex: "Cartão Itaú final 1234"

  // Cartão (NUNCA armazenar PAN — só os 4 últimos dígitos e bandeira)
  bandeira          String?
  ultimosDigitos    String?
  validadeMes       Int?
  validadeAno       Int?

  // Token do gateway (referência segura, sem dados sensíveis)
  gatewayTokenId    String?

  padrao            Boolean        @default(false)
  ativo             Boolean        @default(true)
  criadoEm          DateTime       @default(now())

  @@index([contaId])
}

model EventoGateway {
  id          String    @id @default(cuid())
  cobrancaId  String?
  cobranca    Cobranca? @relation(fields: [cobrancaId], references: [id], onDelete: Cascade)
  provider    GatewayProvider
  evento      String    // ex: "PAYMENT_CONFIRMED", "PAYMENT_OVERDUE"
  payload     String    // JSON serializado
  recebidoEm  DateTime  @default(now())

  @@index([cobrancaId])
  @@index([evento])
}

// ============================================================
// NOTIFICAÇÕES INTERNAS DO SISTEMA (sininho + central)
// ============================================================

enum TipoNotificacaoSistema {
  PRAZO_PROXIMO            // execução com data de execução/pagamento próxima
  STATUS_PAGO              // execução mudou pra PAGO (analista é avisado)
  NOVA_EXECUCAO            // empresa cadastrou nova execução em contrato vinculado ao analista
  VINCULO_CRIADO           // empresa vinculou um analista
  VINCULO_ENCERRADO
  COMISSAO_DISPONIVEL      // valor a receber consolidado mensal
  AVISO_VENCIMENTO_FATURA  // assinatura SaaS vencendo
}

model NotificacaoSistema {
  id              String                @id @default(cuid())
  usuarioId       String                // destinatário
  usuario         Usuario               @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  tipo            TipoNotificacaoSistema
  titulo          String
  descricao       String?
  link            String?               // rota interna (ex: "/execucao/abc123")
  recursoTipo     String?               // ex: "Empenho", "VinculoAnalista"
  recursoId       String?
  lida            Boolean               @default(false)
  lidaEm          DateTime?
  criadoEm        DateTime              @default(now())

  @@index([usuarioId, lida])
  @@index([criadoEm])
}

// Configuração singleton (1 linha por instalação) das credenciais do gateway
model ConfiguracaoGateway {
  id              String          @id @default("singleton")
  provider        GatewayProvider @default(DEMO)
  ambiente        String          @default("sandbox") // sandbox | production
  apiKey          String?         // criptografada em produção
  webhookToken    String?         // valida POSTs do gateway
  atualizadoEm    DateTime        @updatedAt
  atualizadoPor   String?
}
