# =============================================================
# CP System — variáveis de ambiente
# =============================================================
# Copie este arquivo pra `.env` e preencha os valores.

# Banco de dados (SQLite local em dev; troque pra Postgres em prod)
DATABASE_URL="file:./dev.db"

# Sessão (gere com: openssl rand -base64 32)
AUTH_SECRET="dev-secret-trocar-em-prod-com-openssl-rand-base64-32"
AUTH_URL="http://localhost:3001"

# =============================================================
# GATEWAY DE PAGAMENTO
# =============================================================
# Você pode configurar o gateway de duas formas:
# 1. Pela UI em /admin/gateway (recomendado — fica no banco)
# 2. Via env vars abaixo (sobrescrito pela UI se houver config)
#
# Provider: ASAAS | STRIPE | DEMO
GATEWAY_PROVIDER="DEMO"

# ASAAS (gateway brasileiro com PIX/boleto/cartão nativos)
# Pegue a key em https://www.asaas.com/customer/integrations
ASAAS_API_KEY=""
ASAAS_AMBIENTE="sandbox"   # sandbox | production
ASAAS_WEBHOOK_TOKEN=""     # mesmo valor configurado em ASAAS → Notificações

# Webhook URL pra configurar no ASAAS:
#   Sandbox:    https://seu-dominio.dev/api/webhooks/asaas
#   Produção:   https://seu-dominio.com.br/api/webhooks/asaas

# =============================================================
# IA — Extração automática de PDFs (Atas, Contratos, Empenhos)
# =============================================================
# Pegue em https://console.anthropic.com (modelo usado: claude-haiku-4-5)
# Sem essa chave o botão "Anexar PDF da Ata" no formulário de Nova Ata exibe erro.
ANTHROPIC_API_KEY=""

# =============================================================
# EM ROADMAP (configure quando integrar)
# =============================================================
# WHATSAPP_PROVIDER=""       # zapi | evolution | twilio
# WHATSAPP_API_KEY=""
# WHATSAPP_INSTANCE_ID=""
